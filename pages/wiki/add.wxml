<view class="container">
  <view class="card">
    <view class="field-label">标题（可留空）</view>
    <input class="input-field" value="{{title}}" bindinput="onTitleInput" placeholder="如 周末买菜小记" />

    <view class="field-label">说说今天买菜的心得</view>
    <textarea class="textarea-field" value="{{rawText}}" bindinput="onRawInput" placeholder="可以按住下面的话筒说，也可以直接打字" auto-height></textarea>

    <button class="voice-btn {{recording ? 'on' : ''}}" wx:if="{{voiceAvailable}}"
      bindtouchstart="onVoiceStart" bindtouchend="onVoiceEnd" bindtouchcancel="onVoiceEnd">
      {{recording ? '🔴 松开结束' : '🎤 按住说话'}}
    </button>
    <view wx:else class="voice-tip">（未启用语音插件，直接打字即可）</view>

    <button class="btn-secondary organize-btn" bindtap="onOrganize" loading="{{organizing}}" disabled="{{organizing}}">✨ AI 整理成小记</button>

    <block wx:if="{{content}}">
      <view class="field-label">整理后的小记（可修改）</view>
      <textarea class="textarea-field" value="{{content}}" bindinput="onContentInput" placeholder="AI 整理后的内容" auto-height></textarea>
    </block>

    <view class="share-row">
      <text class="share-label">分享到菜友圈</text>
      <switch checked="{{isPublic}}" bindchange="onTogglePublic" color="#47672c" />
    </view>
  </view>

  <button class="btn-primary save-btn" bindtap="onSave" loading="{{saving}}" disabled="{{saving}}">保存</button>
</view>
