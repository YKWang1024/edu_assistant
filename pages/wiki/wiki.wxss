.add-btn {
  width: 100%;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #f9b94e, #f5a623);
  box-shadow: 0 12rpx 24rpx rgba(245, 166, 35, 0.28);
}
.empty-tip { text-align: center; color: #a0a0ad; font-size: 26rpx; padding: 60rpx 30rpx; line-height: 1.6; }

.w-item { padding: 26rpx 28rpx; margin-bottom: 18rpx; }
.w-top { display: flex; align-items: baseline; justify-content: space-between; }
.w-title { font-size: 30rpx; font-weight: 800; color: #2b2b33; }
.w-date { font-size: 22rpx; color: #a0a0ad; }
.w-content { font-size: 27rpx; color: #5a5a66; line-height: 1.75; margin: 16rpx 0; white-space: pre-wrap; }
.w-foot { display: flex; align-items: center; border-top: 2rpx solid #f1f3f7; padding-top: 16rpx; }
.w-public { font-size: 22rpx; color: #3f8d57; font-weight: 700; }
.w-private { font-size: 22rpx; color: #a0a0ad; }
.w-actions { margin-left: auto; display: flex; gap: 20rpx; }
.w-action { font-size: 24rpx; font-weight: 700; color: #d98a2b; }
.w-action.danger { color: #e5484d; }
