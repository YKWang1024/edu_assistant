<view class="container" wx:if="{{recipe}}">
  <view class="recipe-header">
    <view class="user-bar">
      <image wx:if="{{recipe.userAvatar}}" src="{{recipe.userAvatar}}" class="user-avatar" />
      <view wx:else class="user-avatar-placeholder">👤</view>
      <view class="user-info">
        <text class="user-name">{{recipe.userName || '匿名用户'}}</text>
        <text class="share-time">{{recipe.createdAt ? recipe.createdAt.split('T')[0] : ''}}</text>
      </view>
    </view>
  </view>

  <view class="recipe-images">
    <swiper class="image-swiper" indicator-dots="{{recipe.images && recipe.images.length > 1}}" autoplay circular>
      <swiper-item wx:for="{{recipe.images || [recipe.imageUrl]}}" wx:key="index">
        <image src="{{item}}" mode="aspectFill" class="swiper-image" bindtap="onPreviewImage" data-src="{{item}}" />
      </swiper-item>
    </swiper>
  </view>

  <view class="recipe-content">
    <view class="recipe-title-row">
      <text class="recipe-name">{{recipe.name}}</text>
      <text class="recipe-category">{{recipe.category}}</text>
    </view>

    <view class="recipe-stats" bindtap="onToggleRatings">
      <view class="stat-item">
        <text class="stat-icon">⭐</text>
        <text class="stat-value">{{recipe.avgScore || 0}}分</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">👨🍳</text>
        <text class="stat-value">{{ratingCount}}人评分</text>
      </view>
      <text class="stat-toggle" wx:if="{{ratingCount > 0}}">{{showRatings ? '收起 ▲' : '查看全部评分 ▼'}}</text>
    </view>

    <!-- 全部评分(菜友圈全局可见，REQ-009)：评分人/分数/评价/时间 -->
    <view class="ratings-panel" wx:if="{{showRatings && ratingCount > 0}}">
      <view class="rating-row" wx:for="{{ratingList}}" wx:key="id">
        <view class="rating-line1">
          <text class="rating-name">{{item.memberName}}</text>
          <text class="rating-score">{{item.score}}分</text>
        </view>
        <view class="rating-comment" wx:if="{{item.comment}}">{{item.comment}}</view>
        <text class="rating-time">{{item.date}} {{item.time}}</text>
      </view>
    </view>

    <view class="section">
      <text class="section-title">食材</text>
      <text class="section-content">{{recipe.ingredients || '暂无'}}</text>
    </view>

    <view class="section">
      <text class="section-title">做法</text>
      <text class="section-content">{{recipe.steps || '暂无'}}</text>
    </view>

    <view class="section" wx:if="{{recipe.tags}}">
      <text class="section-title">标签</text>
      <text class="section-content">{{recipe.tags}}</text>
    </view>
  </view>
</view>