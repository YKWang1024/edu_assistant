<view class="container">
  <view class="page-header">
    <view class="header-title">🍳 菜友圈</view>
    <view class="header-subtitle">发现更多美味菜谱</view>
  </view>

  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view class="recipe-list" wx:else>
    <view class="empty-tip" wx:if="{{recipes.length === 0}}">
      暂无分享的菜谱，快来分享你的拿手菜吧！
    </view>

    <view class="recipe-card card" wx:for="{{recipes}}" wx:key="_id" bindtap="onViewRecipe" data-recipe="{{item}}">
      <view class="card-header">
        <image wx:if="{{item.userAvatar}}" src="{{item.userAvatar}}" class="user-avatar" />
        <view wx:else class="user-avatar-placeholder">👤</view>
        <view class="user-info">
          <text class="user-name">{{item.userName || '匿名用户'}}</text>
          <text class="share-time">{{item.createdAt ? item.createdAt.split('T')[0] : ''}}</text>
        </view>
      </view>

      <view class="card-body">
        <view class="recipe-images" wx:if="{{item.images && item.images.length > 0}}">
          <image wx:for="{{item.images.slice(0, 3)}}" wx:key="index" src="{{item}}" class="recipe-image" mode="aspectFill" />
        </view>
        <view class="recipe-images" wx:elif="{{item.imageUrl}}">
          <image src="{{item.imageUrl}}" class="recipe-image" mode="aspectFill" />
        </view>

        <view class="recipe-info">
          <text class="recipe-name">{{item.name}}</text>
          <text class="recipe-category">{{item.category}}</text>
        </view>

        <view class="recipe-desc" wx:if="{{item.ingredients}}">
          {{item.ingredients.slice(0, 100)}}{{item.ingredients.length > 100 ? '...' : ''}}
        </view>

        <view class="recipe-stats">
          <view class="stat-item">
            <text class="stat-icon">⭐</text>
            <text class="stat-value">{{item.avgScore || 0}}分</text>
          </view>
          <view class="stat-item">
            <text class="stat-icon">👨🍳</text>
            <text class="stat-value">{{item.ratings ? item.ratings.length : 0}}人评分</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="share-fab" bindtap="onShareRecipe">
    <text class="fab-icon">+</text>
  </view>
</view>