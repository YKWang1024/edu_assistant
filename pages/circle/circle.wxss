.container {
  min-height: 100vh;
  background: #fef9ed;
}

.empty-cta {
  margin-top: 24rpx;
  display: inline-block;
}

/* 买菜心得入口 + 信息流 */
.wiki-entry {
  margin-top: 16rpx;
  display: inline-block;
  font-size: 24rpx;
  font-weight: 700;
  color: #fef9ed;
  background: rgba(255,255,255,0.18);
  border: 2rpx solid rgba(255,255,255,0.5);
  border-radius: 30rpx;
  padding: 8rpx 22rpx;
}
.wiki-feed {
  padding: 20rpx 24rpx 0;
}
.wiki-feed-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #5e4700;
  margin-bottom: 12rpx;
  font-family: 'PingFang SC', monospace;
}
.wiki-feed-card {
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}
.wiki-feed-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.wiki-feed-name { font-size: 26rpx; font-weight: 700; color: #1d1c15; }
.wiki-feed-date { font-size: 22rpx; color: #807661; }
.wiki-feed-h { font-size: 27rpx; font-weight: 700; color: #1d1c15; margin-top: 8rpx; }
.wiki-feed-body {
  font-size: 26rpx;
  color: #1d1c15;
  line-height: 1.7;
  margin-top: 8rpx;
  white-space: pre-wrap;
}

.page-header {
  background: linear-gradient(135deg, #775a00 0%, #47672c 100%);
  padding: 60rpx 30rpx 40rpx;
  color: #fef9ed;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 26rpx;
  opacity: 0.8;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #d2c5ad;
  border-top-color: #775a00;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #807661;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 40rpx;
  font-size: 28rpx;
  color: #807661;
}

.recipe-list {
  padding: 20rpx;
}

.recipe-card {
  background: #fef9ed;
  border: 4rpx solid #807661;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.card-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #d2c5ad;
}

.user-avatar-placeholder {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #d2c5ad;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1c15;
  display: block;
}

.share-time {
  font-size: 22rpx;
  color: #807661;
}

.card-body {
  padding: 0 20rpx 20rpx;
}

.recipe-images {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.recipe-image {
  width: calc(33.33% - 6rpx);
  height: 200rpx;
  border-radius: 8rpx;
}

.recipe-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.recipe-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d1c15;
}

.recipe-category {
  font-size: 24rpx;
  color: #fef9ed;
  background: #47672c;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.recipe-desc {
  font-size: 26rpx;
  color: #807661;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.recipe-stats {
  display: flex;
  gap: 30rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-icon {
  font-size: 28rpx;
}

.stat-value {
  font-size: 26rpx;
  color: #4e4634;
}

.share-fab {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: #775a00;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.3);
  border: 4rpx solid #4e3d00;
}

.fab-icon {
  font-size: 56rpx;
  color: #fef9ed;
  line-height: 1;
}

.share-fab:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0rpx 0rpx rgba(136, 81, 32, 0.3);
}