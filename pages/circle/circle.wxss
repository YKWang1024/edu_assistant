.container {
  min-height: 100vh;
  padding: 0 0 40rpx;
}

/* ---------- 顶部渐变 banner ---------- */
.page-header {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #6cc06f 0%, #4ca85f 60%, #4b86ef 130%);
  border-radius: 0 0 36rpx 36rpx;
  padding: 50rpx 36rpx 40rpx;
  color: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(76, 168, 95, 0.24);
}
.page-header::after {
  content: '';
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
  top: -100rpx;
  right: -50rpx;
}
.header-title {
  position: relative;
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 6rpx rgba(40, 110, 70, 0.25);
}
.header-subtitle {
  position: relative;
  font-size: 25rpx;
  opacity: 0.92;
}

/* ---------- 买菜心得入口 ---------- */
.wiki-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 24rpx 0;
  padding: 26rpx 28rpx;
  background: linear-gradient(160deg, #fdf0d9 0%, #fbe3bd 100%);
  border: none;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(245, 166, 35, 0.16);
  transition: transform 0.12s ease;
}
.wiki-entry-card:active { transform: scale(0.98); }
.wiki-entry-left { display: flex; align-items: center; gap: 18rpx; }
.wiki-entry-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
}
.wiki-entry-title { font-size: 30rpx; font-weight: 800; color: #7a5410; }
.wiki-entry-sub { font-size: 22rpx; color: #b08838; margin-top: 4rpx; }
.wiki-entry-arrow { font-size: 40rpx; color: #d2a86a; font-weight: 300; }

/* ---------- 心得信息流 ---------- */
.wiki-feed { padding: 24rpx 24rpx 0; }
.wiki-feed-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2b2b33;
  margin: 8rpx 4rpx 16rpx;
}
.wiki-feed-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 26rpx 28rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 22rpx rgba(80, 95, 130, 0.07);
}
.wiki-feed-top { display: flex; align-items: baseline; justify-content: space-between; }
.wiki-feed-name { font-size: 26rpx; font-weight: 700; color: #2b2b33; }
.wiki-feed-date { font-size: 22rpx; color: #a0a0ad; }
.wiki-feed-h { font-size: 28rpx; font-weight: 700; color: #2b2b33; margin-top: 10rpx; }
.wiki-feed-body {
  font-size: 26rpx;
  color: #5a5a66;
  line-height: 1.7;
  margin-top: 8rpx;
  white-space: pre-wrap;
}

/* ---------- 加载 / 空态 ---------- */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #e3e7ef;
  border-top-color: #4ca85f;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 20rpx; font-size: 26rpx; color: #a0a0ad; }

.empty-tip {
  text-align: center;
  padding: 90rpx 40rpx;
  font-size: 28rpx;
  color: #a0a0ad;
}
.empty-cta { margin-top: 28rpx; display: inline-block; }

/* ---------- 菜友菜谱卡 ---------- */
.recipe-list { padding: 24rpx; }

.recipe-card {
  background: #ffffff;
  border: none;
  border-radius: 28rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(80, 95, 130, 0.08);
  transition: transform 0.12s ease;
}
.recipe-card:active { transform: scale(0.99); }

.card-header { display: flex; align-items: center; padding: 24rpx 26rpx 16rpx; gap: 16rpx; }
.user-avatar { width: 76rpx; height: 76rpx; border-radius: 50%; }
.user-avatar-placeholder {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #eaeef5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.user-info { flex: 1; }
.user-name { font-size: 29rpx; font-weight: 700; color: #2b2b33; display: block; }
.share-time { font-size: 22rpx; color: #a0a0ad; }

.card-body { padding: 0 26rpx 26rpx; }
.recipe-images { display: flex; gap: 10rpx; margin-bottom: 18rpx; }
.recipe-image { width: calc(33.33% - 7rpx); height: 200rpx; border-radius: 16rpx; }

@keyframes feedIn { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: translateY(0); } }
.recipe-card, .wiki-feed-card { animation: feedIn 0.4s ease both; }
.recipe-card:nth-child(2) { animation-delay: 0.05s; }
.recipe-card:nth-child(3) { animation-delay: 0.10s; }
.recipe-card:nth-child(4) { animation-delay: 0.15s; }

.recipe-info { display: flex; align-items: center; gap: 16rpx; margin-bottom: 10rpx; }
.recipe-name { font-size: 32rpx; font-weight: 800; color: #2b2b33; }
.recipe-category {
  font-size: 22rpx;
  color: #4ca85f;
  background: #e3f4e0;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 700;
}
.recipe-desc { font-size: 25rpx; color: #8a8a97; line-height: 1.6; margin-bottom: 18rpx; }

.recipe-stats { display: flex; gap: 30rpx; }
.stat-item { display: flex; align-items: center; gap: 8rpx; }
.stat-icon { font-size: 26rpx; }
.stat-value { font-size: 25rpx; color: #6b6b7a; font-weight: 600; }

/* ---------- 悬浮按钮 ---------- */
.share-fab {
  position: fixed;
  right: 30rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #6cc06f, #4ca85f);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(76, 168, 95, 0.4);
  border: none;
}
.fab-icon { font-size: 52rpx; color: #ffffff; line-height: 1; }
.share-fab:active { transform: scale(0.94); }

/* 菜友圈排序/筛选条(REQ-009) */
.sort-bar { display: flex; gap: 14rpx; padding: 4rpx 4rpx 20rpx; }
.sort-chip {
  padding: 10rpx 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #e6e9f0;
  font-size: 24rpx;
  color: #6a6a78;
}
.sort-chip.active { background: #4ca85f; border-color: #4ca85f; color: #ffffff; }
.sort-chip.filter { margin-left: auto; }
