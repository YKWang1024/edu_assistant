.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #2b2b33;
  margin-bottom: 24rpx;
}
.section-title .icon { margin-right: 12rpx; font-size: 36rpx; }

.member-card { margin-bottom: 16rpx; }
.member-row { padding: 18rpx 0; border-bottom: 2rpx solid #f1f3f7; }
.member-row:last-child { border-bottom: none; }
.member-display { width: 100%; }
.member-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: #fdeede;
  color: #d98a2b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  margin-right: 16rpx;
  text-align: center;
  line-height: 60rpx;
  border: none;
}
.member-name { font-size: 28rpx; font-weight: 700; color: #2b2b33; }
.member-actions { display: flex; gap: 12rpx; align-items: center; }
.edit-btn {
  font-size: 24rpx;
  color: #4ca85f;
  padding: 8rpx 22rpx;
  border: none;
  border-radius: 999rpx;
  background: #e3f4e0;
  font-weight: 700;
}
.edit-btn:active { transform: scale(0.95); }
.remove-btn {
  font-size: 24rpx;
  color: #e5484d;
  padding: 8rpx 22rpx;
  border: none;
  border-radius: 999rpx;
  background: #ffe9e6;
  font-weight: 700;
}
.remove-btn:active { transform: scale(0.95); }

.member-edit { padding: 4rpx 0; }
.edit-row { display: flex; gap: 12rpx; align-items: center; }
.edit-input { flex: 1; margin-bottom: 0; }
.edit-btns { display: flex; gap: 10rpx; align-items: center; }
.save-btn {
  font-size: 24rpx;
  color: #ffffff;
  padding: 12rpx 24rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #6cc06f, #4ca85f);
  font-weight: 700;
}
.save-btn:active { transform: scale(0.95); }
.cancel-btn {
  font-size: 24rpx;
  color: #6b6b7a;
  padding: 12rpx 24rpx;
  border: none;
  border-radius: 999rpx;
  background: #f1f3f7;
  font-weight: 700;
}
.cancel-btn:active { transform: scale(0.95); }

.add-member { margin-bottom: 16rpx; }
.add-row { display: flex; gap: 16rpx; align-items: center; }
.add-input { flex: 1; margin-bottom: 0; }
.add-btn { width: 150rpx; height: 80rpx; line-height: 80rpx; padding: 0; font-size: 26rpx; }

.tip-card {
  padding: 26rpx 28rpx;
  background: #f4faf3;
  border: none;
  border-radius: 24rpx;
  box-shadow: none;
}
.tip-title { font-size: 28rpx; font-weight: 700; color: #3f8d57; margin-bottom: 12rpx; }
.tip-item { font-size: 24rpx; color: #6b6b7a; line-height: 1.8; }
