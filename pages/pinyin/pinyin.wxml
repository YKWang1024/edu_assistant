<view class="container" wx:if="{{mode === 'select'}}">
  <view class="select-header">
    <view class="select-title">📖 语文拼音</view>
    <view class="select-desc">选择练习方式</view>
  </view>

  <view class="section-label">练习模式</view>
  <view class="mode-list">
    <view
      class="mode-item {{selectedMode === item.key ? 'active' : ''}}"
      wx:for="{{practiceModes}}"
      wx:key="key"
      data-mode="{{item.key}}"
      bindtap="onSelectMode"
    >
      <view class="mode-icon">{{item.icon}}</view>
      <view class="mode-info">
        <view class="mode-name">{{item.name}}</view>
        <view class="mode-desc">{{item.desc}}</view>
      </view>
      <view class="mode-check" wx:if="{{selectedMode === item.key}}">✓</view>
    </view>
  </view>

  <view class="section-label">字表选择</view>
  <view class="mode-list">
    <view
      class="mode-item {{selectedList === item.key ? 'active' : ''}}"
      wx:for="{{listTypes}}"
      wx:key="key"
      data-list="{{item.key}}"
      bindtap="onSelectList"
    >
      <view class="mode-icon">{{item.icon}}</view>
      <view class="mode-info">
        <view class="mode-name">{{item.name}}</view>
        <view class="mode-desc">{{item.desc}}</view>
      </view>
      <view class="mode-check" wx:if="{{selectedList === item.key}}">✓</view>
    </view>
  </view>

  <button class="btn-primary start-btn" bindtap="onStartPractice">开始练习</button>
</view>

<view class="container" wx:if="{{mode === 'practice'}}">
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{(currentIndex + 1) / totalQuestions * 100}}%"></view>
  </view>
  <view class="progress-text">第 {{currentIndex + 1}} / {{totalQuestions}} 题</view>

  <view class="question-card pinyin-card">
    <view class="prompt-label" wx:if="{{questions[currentIndex].type === 'char2pinyin'}}">请选出这个字的拼音</view>
    <view class="prompt-label" wx:if="{{questions[currentIndex].type === 'pinyin2char'}}">请选出这个拼音对应的字</view>
    <view class="prompt-label" wx:if="{{questions[currentIndex].type === 'pinyin2write'}}">请写出这个拼音对应的字</view>
    <view class="prompt-text {{questions[currentIndex].type === 'char2pinyin' ? 'char-prompt' : 'pinyin-prompt'}}">
      {{questions[currentIndex].prompt}}
    </view>
  </view>

  <view wx:if="{{questions[currentIndex].type !== 'pinyin2write'}}">
    <view class="options-grid">
      <view
        class="option-btn {{selectedOption === index ? (currentCorrect ? 'correct' : 'wrong') : ''}} {{showResult && questions[currentIndex].options[index] === questions[currentIndex].answer ? 'show-correct' : ''}}"
        wx:for="{{questions[currentIndex].options}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="onSelectOption"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view wx:if="{{questions[currentIndex].type === 'pinyin2write'}}" class="write-area">
    <input
      class="write-input"
      placeholder="请输入汉字"
      value="{{writeAnswer}}"
      bindinput="onWriteInput"
      bindconfirm="onSubmitWrite"
      focus="{{true}}"
    />
    <button class="btn-primary write-submit" bindtap="onSubmitWrite" disabled="{{showResult}}">确定</button>
  </view>

  <view class="result-tip" wx:if="{{showResult}}">
    <text class="tip-text {{currentCorrect ? 'tip-correct' : 'tip-wrong'}}">
      {{currentCorrect ? '✓ 回答正确！' : '✗ 正确答案是「' + questions[currentIndex].answer + '」'}}
    </text>
  </view>
</view>
