.vip-header {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 4rpx solid #807661;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.vip-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #e6b325;
}

.free-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #775a00;
}

.vip-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx;
  text-align: center;
}

.vip-badge {
  font-size: 36rpx;
  font-weight: 700;
  color: #5e4700;
  margin-bottom: 8rpx;
  font-family: 'PingFang SC', monospace;
}

.vip-expiry {
  font-size: 24rpx;
  color: #885120;
  font-family: 'PingFang SC', monospace;
}

.free-badge {
  font-size: 36rpx;
  font-weight: 700;
  color: #fef9ed;
  margin-bottom: 8rpx;
  font-family: 'PingFang SC', monospace;
}

.free-tip {
  font-size: 24rpx;
  color: #f2ede2;
  font-family: 'PingFang SC', monospace;
}

.feature-list {
  margin-bottom: 24rpx;
}

.feature-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.feature-left {
  flex: 1;
}

.feature-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d1c15;
  margin-bottom: 4rpx;
  font-family: 'PingFang SC', monospace;
}

.feature-desc {
  font-size: 22rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
}

.feature-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  border: 4rpx solid #807661;
  font-family: 'PingFang SC', monospace;
}

.feature-tag.free {
  background: #c7efa4;
  color: #0c2000;
}

.feature-tag.vip {
  background: #e6b325;
  color: #5e4700;
}

.vip-card {
  text-align: center;
  padding: 40rpx 30rpx;
  border: 4rpx solid #807661;
  background: #fef9ed;
  margin-bottom: 24rpx;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.vip-card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1c15;
  margin-bottom: 16rpx;
  font-family: 'PingFang SC', monospace;
}

.vip-card-price {
  margin-bottom: 20rpx;
}

.price-amount {
  font-size: 56rpx;
  font-weight: 800;
  color: #885120;
  font-family: 'PingFang SC', monospace;
}

.price-unit {
  font-size: 26rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
}

.vip-card-features {
  text-align: left;
  margin-bottom: 24rpx;
}

.vip-feature {
  font-size: 26rpx;
  color: #4e4634;
  padding: 8rpx 0;
  font-family: 'PingFang SC', monospace;
}

.subscribe-btn {
  width: 80%;
  margin: 0 auto;
}

.action-list {
  margin-top: 10rpx;
}

.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.action-name {
  font-size: 28rpx;
  color: #1d1c15;
  font-family: 'PingFang SC', monospace;
  font-weight: 700;
}

.danger-text {
  color: #ba1a1a;
}

.action-arrow {
  font-size: 32rpx;
  color: #807661;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.sync-card {
  border-left: 8rpx solid #47672c;
  margin-bottom: 24rpx;
}

.sync-status {
  padding: 10rpx 0;
}

.sync-label {
  font-size: 26rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
}

.sync-value {
  font-size: 26rpx;
  color: #4e4634;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.sync-value.active {
  color: #47672c;
}

.sync-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.sync-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
}
