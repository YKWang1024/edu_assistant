.profile {
  padding: 24rpx 24rpx 60rpx;
}

/* ---------- 用户头 ---------- */
.p-hero {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #aed4f5 0%, #7fb8f0 55%, #8ea2f0 100%);
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(110, 150, 220, 0.30);
}
.p-hero-blob { position: absolute; border-radius: 50%; background: rgba(255, 255, 255, 0.16); pointer-events: none; }
.p-hero-blob-1 { width: 220rpx; height: 220rpx; top: -80rpx; right: -40rpx; }
.p-hero-blob-2 { width: 140rpx; height: 140rpx; bottom: -60rpx; left: 40rpx; background: rgba(255, 255, 255, 0.10); }
.p-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-right: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(60, 100, 170, 0.25);
}
.p-info { position: relative; }
.p-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 0 2rpx 6rpx rgba(60, 100, 170, 0.25);
}
.p-meta { margin-top: 10rpx; font-size: 25rpx; font-weight: 600; color: rgba(255, 255, 255, 0.92); }
.p-dot { margin: 0 10rpx; opacity: 0.7; }

/* ---------- 成长档案高亮卡 ---------- */
.archive {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #6cc06f 0%, #4ca85f 100%);
  border-radius: 28rpx;
  padding: 30rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 14rpx 30rpx rgba(76, 168, 95, 0.28);
  transition: transform 0.12s ease;
}
.archive:active { transform: scale(0.98); }
.archive-blob { position: absolute; width: 200rpx; height: 200rpx; border-radius: 50%; background: rgba(255, 255, 255, 0.14); top: -70rpx; right: -30rpx; }
.archive-text { position: relative; }
.archive-title { font-size: 34rpx; font-weight: 800; color: #ffffff; }
.archive-sub { margin-top: 8rpx; font-size: 23rpx; color: rgba(255, 255, 255, 0.9); }
.archive-emoji {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

/* ---------- 设置列表 ---------- */
.menu {
  padding: 8rpx 28rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
}
/* 分享按钮伪装成菜单行：清掉 button 默认样式 */
.menu-share {
  background: transparent;
  border: none;
  margin: 0;
  width: 100%;
  text-align: left;
  line-height: 1.2;
  font-size: 29rpx;
  color: #2b2b33;
}
.menu-share::after { border: none; }
.menu-item:active { opacity: 0.6; }
.menu-left { display: flex; align-items: center; }
.menu-ic {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 22rpx;
}
.ic-purple { background: #efe9fb; }
.ic-blue { background: #e2eefe; }
.ic-green { background: #e3f4e0; }
.ic-orange { background: #fdeede; }
.ic-red { background: #ffe9e6; }
.menu-name { font-size: 29rpx; font-weight: 600; color: #2b2b33; }
.danger-text { color: #e5484d; }
.menu-arrow { font-size: 38rpx; color: #c6c6d0; font-weight: 300; }
.menu-sep { height: 2rpx; background: #f1f3f7; }

.p-version {
  text-align: center;
  font-size: 22rpx;
  color: #b5b5c0;
  margin-top: 36rpx;
}

/* REQ-017 设置页标题(替代原用户信息头) */
.settings-head { font-size: 36rpx; font-weight: 800; color: #2b2b33; padding: 36rpx 8rpx 24rpx; }
