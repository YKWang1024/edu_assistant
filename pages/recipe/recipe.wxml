<view class="container">
  <view class="nutrition-card card" wx:if="{{nutritionAnalysis}}">
    <view class="card-title">
      <text class="icon">🥗</text>
      <text>营养分析</text>
    </view>
    <view class="nutrition-bar">
      <view class="nutrition-progress" style="width: {{nutritionAnalysis.balanceScore}}%"></view>
    </view>
    <view class="nutrition-score">营养均衡度: {{nutritionAnalysis.balanceScore}}%</view>
    <view class="nutrition-tags">
      <view class="tag covered" wx:for="{{nutritionAnalysis.coveredCategories}}" wx:key="*this">
        ✓ {{item}}
      </view>
      <view class="tag missing" wx:for="{{nutritionAnalysis.missingCategories}}" wx:key="*this">
        ✗ {{item}}
      </view>
    </view>
    <view class="nutrition-tip" wx:if="{{nutritionAnalysis.missingCategories.length > 0}}">
      建议补充: {{nutritionAnalysis.missingCategories.join('、')}} 类食物
    </view>
  </view>

  <block wx:if="{{recommendations.length > 0}}">
    <view class="section-title">今日推荐</view>
    <view class="meal-list">
      <view class="meal-card" wx:for="{{recommendations}}" wx:key="id" bindtap="onViewDetail" data-id="{{item.id}}">
        <view class="meal-emoji">{{item.mealEmoji}}</view>
        <view class="meal-body">
          <view class="meal-label">{{item.mealLabel}}</view>
          <view class="meal-name">{{item.name}}</view>
        </view>
        <view class="meal-score">⭐ {{item.avgScore}}</view>
      </view>
    </view>
  </block>

  <view class="section-title flex-between">
    <text>全部菜谱</text>
    <view class="add-btn" bindtap="onAddRecipe">+ 添加菜谱</view>
  </view>

  <view class="filter-bar">
    <view
      class="filter-item {{activeFilter === item ? 'active' : ''}}"
      wx:for="{{filterOptions}}"
      wx:key="*this"
      data-filter="{{item}}"
      bindtap="onFilterChange"
    >
      {{item === 'all' ? '全部' : item}}
    </view>
  </view>

  <!-- 按建议餐次筛选(REQ-020) -->
  <view class="filter-bar">
    <view
      class="filter-item {{mealFilter === item ? 'active' : ''}}"
      wx:for="{{mealFilterOptions}}"
      wx:key="*this"
      data-meal="{{item}}"
      bindtap="onMealFilterChange"
    >
      {{item === 'all' ? '全部餐次' : item}}
    </view>
  </view>

  <view class="empty-state" wx:if="{{recipes.length === 0}}">
    <view class="empty-tip">还没有菜谱～</view>
    <button class="btn-primary empty-cta" bindtap="onImportSystem">📚 从系统菜谱库导入</button>
    <view class="empty-or" bindtap="onAddRecipe">或自己添加一道</view>
  </view>
  <view class="empty-tip" wx:elif="{{displayRecipes.length === 0}}">
    没有符合当前筛选条件的菜谱～
  </view>

  <view class="recipe-list">
    <view class="recipe-item card" wx:for="{{displayRecipes}}" wx:key="id" bindtap="onViewDetail" data-id="{{item.id}}">
      <view class="recipe-thumb">
        <image wx:if="{{item.images[0] || item.imageUrl}}" class="recipe-thumb-img" src="{{item.images[0] || item.imageUrl}}" mode="aspectFill" />
        <view wx:else class="recipe-thumb-img recipe-thumb-ph">{{item.thumbEmoji}}</view>
      </view>
      <view class="recipe-body">
        <view class="recipe-header flex-between">
          <view class="flex-row">
            <text class="recipe-name">{{item.name}}</text>
            <text class="link-indicator" wx:if="{{item.referenceLink}}">{{item.referenceType === 'xiaohongshu' ? '📕' : item.referenceType === 'bilibili' ? '📺' : '🔗'}}</text>
          </view>
          <view class="recipe-score">
            {{item.avgScore > 0 ? '⭐ ' + item.avgScore : '未评分'}}
          </view>
        </view>
        <view class="recipe-meta">
          <text class="recipe-ingredients">{{item.ingredients}}</text>
        </view>
        <view class="recipe-meals" wx:if="{{item.mealTimes.length > 0}}">
          <text class="meal-tag-sm" wx:for="{{item.mealTimes}}" wx:for-item="m" wx:key="*this">{{m}}</text>
        </view>
        <view class="recipe-actions">
          <view class="action-btn rate-btn" catchtap="onRateRecipe" data-id="{{item.id}}">打分</view>
          <view class="action-btn share-btn" catchtap="onShareCircle" data-id="{{item.id}}" data-public="{{item.isPublic}}">{{item.isPublic ? '✓已在菜友圈' : '分享菜友圈'}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="fab-btn" bindtap="onAddRecipe">+</view>
</view>
