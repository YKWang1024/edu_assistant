.page { min-height: 100vh; background: #f3f6fb; padding: 24rpx 24rpx 140rpx; box-sizing: border-box; }
.empty-tip { text-align: center; color: #a0a0ad; font-size: 26rpx; padding: 60rpx 20rpx; line-height: 1.6; }
.sys-hint { font-size: 23rpx; color: #8a8a97; padding: 4rpx 8rpx 20rpx; }

.sys-add {
  text-align: center; padding: 22rpx 0; margin-bottom: 20rpx;
  border: 2rpx dashed #c9cede; border-radius: 18rpx;
  color: #5b6ff0; font-size: 28rpx; font-weight: 600;
}
.sys-add:active { background: #f3f5fb; }

.sys-list { display: flex; flex-direction: column; gap: 16rpx; }
.sys-item {
  display: flex; align-items: center; gap: 18rpx; padding: 20rpx;
  background: #fff; border-radius: 22rpx; border: 3rpx solid transparent;
}
.sys-item.sel { border-color: #4ca85f; background: #f3fbf2; }
.sys-thumb { width: 110rpx; height: 110rpx; border-radius: 16rpx; flex-shrink: 0; }
.sys-thumb-ph { background: #eaeef5; display: flex; align-items: center; justify-content: center; font-size: 50rpx; }
.sys-body { flex: 1; min-width: 0; }
.sys-name { font-size: 29rpx; font-weight: 700; color: #2b2b33; }
.sys-cat { font-size: 22rpx; color: #4ca85f; margin: 4rpx 0; }
.sys-ing { font-size: 23rpx; color: #8a8a97; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sys-check {
  width: 44rpx; height: 44rpx; border-radius: 50%; flex-shrink: 0;
  border: 2rpx solid #cfd4e0; color: #fff; text-align: center; line-height: 44rpx; font-size: 26rpx;
}
.sys-check.on { background: #4ca85f; border-color: #4ca85f; }
.sys-ops { display: flex; flex-direction: column; gap: 12rpx; flex-shrink: 0; }
.sys-op { font-size: 24rpx; color: #5b6ff0; }
.sys-op.danger { color: #e5484d; }

.sys-import-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.96); box-shadow: 0 -6rpx 18rpx rgba(80,110,170,0.08);
}
