.image-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 4rpx solid #807661;
}

.remove-img {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ffdad6;
  color: #93000a;
  border: 4rpx solid #807661;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f2ede2;
  border: 4rpx dashed #807661;
  border-radius: 12rpx;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
}

.image-add:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

.add-icon {
  font-size: 56rpx;
  color: #807661;
  line-height: 1;
  font-weight: 700;
}

.add-text {
  font-size: 22rpx;
  color: #807661;
  margin-top: 6rpx;
  font-family: 'PingFang SC', monospace;
}

.form-card {
  padding: 30rpx;
}

.edit-hint {
  font-size: 22rpx;
  color: #4e4634;
  font-weight: 400;
  margin-left: 10rpx;
  font-family: 'PingFang SC', monospace;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #1d1c15;
  font-weight: 700;
  margin-bottom: 12rpx;
  font-family: 'PingFang SC', monospace;
}

.time-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1d1c15;
  background: #fef9ed;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
  font-family: 'PingFang SC', monospace;
}

.picker-arrow {
  font-size: 20rpx;
  color: #807661;
}

.nutrition-text {
  font-size: 26rpx;
  color: #47672c;
  line-height: 1.8;
  padding: 16rpx;
  background: #c7efa4;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  font-family: 'PingFang SC', monospace;
}

.link-type-tag {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  background: #f2ede2;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
}

.link-type-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.link-type-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
}

.save-btn {
  width: 100%;
  margin-top: 20rpx;
}
