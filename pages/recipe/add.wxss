/* AI 识别热量等次按钮：橙色软胶囊 */
.btn-secondary {
  background: linear-gradient(135deg, #f9b94e, #f5a623);
  color: #ffffff;
  border: none;
  border-radius: 999rpx;
  padding: 16rpx 36rpx;
  font-size: 26rpx;
  font-weight: 700;
  margin-top: 12rpx;
  box-shadow: 0 8rpx 18rpx rgba(245, 166, 35, 0.26);
}
.btn-secondary:active { transform: translateY(2rpx); }
.analyze-btn { margin-left: auto; display: block; }

.calories-card { background: linear-gradient(160deg, #fff8ec 0%, #fdeed3 100%); border: none; margin-bottom: 28rpx; }
.calories-header { display: flex; align-items: center; gap: 12rpx; padding: 22rpx; border-bottom: 2rpx dashed #f3cf94; }
.calories-icon { font-size: 36rpx; }
.calories-title { font-size: 28rpx; font-weight: 700; color: #b07a00; }
.calories-content { padding: 22rpx; }
.calories-main { text-align: center; margin-bottom: 20rpx; }
.calories-value { font-size: 64rpx; font-weight: 800; color: #d98a2b; }
.calories-unit { font-size: 28rpx; color: #b08838; margin-left: 8rpx; }
.calories-details { display: flex; justify-content: space-around; padding-bottom: 16rpx; border-bottom: 2rpx dashed #f3cf94; }
.detail-item { text-align: center; }
.detail-label { display: block; font-size: 24rpx; color: #b08838; margin-bottom: 6rpx; }
.detail-value { font-size: 28rpx; font-weight: 700; color: #6b6b7a; }
.calories-confidence { text-align: center; font-size: 22rpx; color: #b08838; margin-top: 12rpx; }

.image-list { display: flex; gap: 16rpx; flex-wrap: wrap; }
.image-item { position: relative; width: 200rpx; height: 200rpx; }
.image-thumb { width: 200rpx; height: 200rpx; border-radius: 18rpx; border: none; }
.remove-img {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  background: #e5484d;
  color: #ffffff;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}
.image-add {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f7f8fb;
  border: 3rpx dashed #cdd2dc;
  border-radius: 18rpx;
}
.image-add:active { transform: scale(0.97); }
.add-icon { font-size: 56rpx; color: #b5b5c0; line-height: 1; font-weight: 300; }
.add-text { font-size: 22rpx; color: #a0a0ad; margin-top: 6rpx; }

.form-card { padding: 30rpx; }
.edit-hint { font-size: 22rpx; color: #a0a0ad; font-weight: 400; margin-left: 10rpx; }
.form-group { margin-bottom: 28rpx; }
.form-label { display: block; font-size: 28rpx; color: #2b2b33; font-weight: 700; margin-bottom: 12rpx; }
.time-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 2rpx solid #eceef4;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2b2b33;
  background: #f7f8fb;
}
.picker-arrow { font-size: 20rpx; color: #a0a0ad; }
.nutrition-text {
  font-size: 26rpx;
  color: #3f8d57;
  line-height: 1.8;
  padding: 16rpx 18rpx;
  background: #e8f6e7;
  border: none;
  border-radius: 16rpx;
}
.link-type-tag {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 8rpx 20rpx;
  background: #f1f3f7;
  border: none;
  border-radius: 999rpx;
}
.link-type-icon { font-size: 24rpx; margin-right: 8rpx; }
.link-type-text { font-size: 24rpx; font-weight: 700; color: #6b6b7a; }
.save-btn { width: 100%; margin-top: 20rpx; }

/* 建议餐次 chips(REQ-020) + 编辑图片提示(REQ-021) */
.meal-chips { display: flex; gap: 16rpx; }
.meal-chip {
  padding: 14rpx 34rpx; border-radius: 999rpx;
  background: #f3f5fb; border: 2rpx solid #e6e9f0;
  font-size: 27rpx; color: #6a6a78;
}
.meal-chip.on { background: #4ca85f; border-color: #4ca85f; color: #fff; font-weight: 600; }
.img-edit-hint { font-size: 23rpx; color: #a0a0ad; margin-top: 8rpx; }
