/* ---------- 营养分析卡 ---------- */
.nutrition-card {
  border-left: none;
  background: linear-gradient(160deg, #ffffff 0%, #f4faf3 100%);
}

.nutrition-bar {
  height: 18rpx;
  background: #e9edf4;
  border: none;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}
.nutrition-progress {
  height: 100%;
  background: linear-gradient(90deg, #6cc06f, #4ca85f);
  border-radius: 999rpx;
  transition: width 0.5s ease;
}
.nutrition-score {
  font-size: 26rpx;
  color: #6b6b7a;
  margin-bottom: 18rpx;
  font-weight: 600;
}
.nutrition-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.tag {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  border: none;
}
.tag.covered { background: #e3f4e0; color: #3f8d57; }
.tag.missing { background: #ffe9e6; color: #e5484d; }
.nutrition-tip {
  font-size: 24rpx;
  color: #f5a623;
  padding: 10rpx 0;
  font-weight: 600;
}

/* ---------- 今日推荐（三餐）---------- */
.meal-list { margin-bottom: 28rpx; }
.meal-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(80, 95, 130, 0.07);
  border-left: 8rpx solid #f5a623;
  transition: transform 0.12s ease;
}
.meal-card:active { transform: scale(0.985); }
.meal-emoji {
  width: 78rpx;
  height: 78rpx;
  border-radius: 20rpx;
  background: #fdeede;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  margin-right: 22rpx;
  flex-shrink: 0;
}
.meal-body { flex: 1; min-width: 0; }
.meal-label { font-size: 22rpx; font-weight: 700; color: #d98a2b; margin-bottom: 4rpx; }
.meal-name { font-size: 30rpx; font-weight: 700; color: #2b2b33; }
.meal-score { font-size: 24rpx; color: #f5a623; font-weight: 700; flex-shrink: 0; }

.add-btn { font-size: 26rpx; color: #4ca85f; font-weight: 700; }

/* ---------- 分类筛选 ---------- */
.filter-bar {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
  overflow-x: auto;
}
.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #ffffff;
  color: #6b6b7a;
  white-space: nowrap;
  border: none;
  font-weight: 600;
  box-shadow: 0 4rpx 14rpx rgba(80, 95, 130, 0.06);
}
.filter-item.active {
  background: linear-gradient(135deg, #6cc06f, #4ca85f);
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(76, 168, 95, 0.28);
}
.filter-item:active { transform: scale(0.96); }

/* ---------- 菜谱卡 ---------- */
@keyframes listIn { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: translateY(0); } }
.recipe-item {
  margin-bottom: 18rpx;
  display: flex;
  padding: 22rpx;
  overflow: hidden;
  animation: listIn 0.35s ease both;
}
.recipe-item:nth-child(2) { animation-delay: 0.04s; }
.recipe-item:nth-child(3) { animation-delay: 0.08s; }
.recipe-item:nth-child(4) { animation-delay: 0.12s; }
.recipe-item:nth-child(5) { animation-delay: 0.16s; }

.recipe-thumb { width: 150rpx; min-height: 150rpx; flex-shrink: 0; margin-right: 22rpx; }
.recipe-thumb-img { width: 150rpx; height: 150rpx; border-radius: 18rpx; box-sizing: border-box; }
.recipe-thumb-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  background: #f1f4f8;
}

.recipe-body { flex: 1; min-width: 0; }
.recipe-header { margin-bottom: 10rpx; }
.recipe-name { font-size: 30rpx; font-weight: 800; color: #2b2b33; }
.link-indicator { font-size: 24rpx; margin-left: 8rpx; }
.recipe-score { font-size: 24rpx; color: #f5a623; font-weight: 700; }
.recipe-meta { margin-bottom: 14rpx; }
.recipe-ingredients {
  font-size: 24rpx;
  color: #8a8a97;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.recipe-actions { display: flex; gap: 16rpx; }
.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  border: none;
}
.action-btn:active { transform: scale(0.95); }
.rate-btn { background: #fdeede; color: #d98a2b; }
.share-btn { background: #e3f4e0; color: #3f8d57; }

/* ---------- 悬浮添加 ---------- */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6cc06f, #4ca85f);
  color: #ffffff;
  font-size: 52rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 14rpx 30rpx rgba(76, 168, 95, 0.4);
  z-index: 100;
}
.fab-btn:active { transform: scale(0.94); }

/* 列表卡片上的建议餐次小标签(REQ-020) */
.recipe-meals { display: flex; gap: 8rpx; margin-top: 6rpx; flex-wrap: wrap; }
.meal-tag-sm { font-size: 20rpx; color: #4ca85f; background: #e8f5e6; border-radius: 999rpx; padding: 2rpx 14rpx; }

/* 空菜谱页：从系统菜谱导入入口(REQ-022) */
.empty-state { text-align: center; padding: 60rpx 30rpx; }
.empty-cta { margin: 24rpx auto 0; max-width: 460rpx; }
.empty-or { margin-top: 22rpx; font-size: 25rpx; color: #5b6ff0; }
