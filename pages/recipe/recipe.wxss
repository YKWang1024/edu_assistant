.nutrition-card {
  border-left: 8rpx solid #47672c;
}

.nutrition-bar {
  height: 16rpx;
  background: #dedace;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.nutrition-progress {
  height: 100%;
  background: #47672c;
  border-radius: 4rpx;
  transition: width 0.5s;
}

.nutrition-score {
  font-size: 26rpx;
  color: #4e4634;
  margin-bottom: 16rpx;
  font-family: 'PingFang SC', monospace;
}

.nutrition-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  border: 4rpx solid #807661;
  font-family: 'PingFang SC', monospace;
}

.tag.covered {
  background: #c7efa4;
  color: #0c2000;
}

.tag.missing {
  background: #ffdad6;
  color: #93000a;
}

.nutrition-tip {
  font-size: 24rpx;
  color: #885120;
  padding: 10rpx 0;
  font-family: 'PingFang SC', monospace;
}

.recommend-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.recommend-list {
  display: inline-flex;
  gap: 16rpx;
}

.recommend-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #f2ede2;
  border: 4rpx solid #807661;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  min-width: 160rpx;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
  font-family: 'PingFang SC', monospace;
}

.recommend-item:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

.recommend-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d1c15;
  margin-bottom: 6rpx;
}

.recommend-score {
  font-size: 22rpx;
  color: #e6b325;
  font-weight: 700;
}

.add-btn {
  font-size: 26rpx;
  color: #775a00;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
}

.filter-item {
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #f2ede2;
  color: #4e4634;
  white-space: nowrap;
  border: 4rpx solid #807661;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
  box-shadow: 4rpx 4rpx 0rpx 0rpx rgba(136, 81, 32, 0.15);
}

.filter-item.active {
  background: #e6b325;
  color: #5e4700;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(255, 255, 255, 0.4), 4rpx 4rpx 0rpx 0rpx rgba(136, 81, 32, 0.15);
}

.filter-item:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

@keyframes listIn { from { opacity: 0; } to { opacity: 1; } }
.recipe-item {
  margin-bottom: 16rpx;
  display: flex;
  overflow: hidden;
  animation: listIn 0.35s ease both;
}
.recipe-item:nth-child(2) { animation-delay: 0.04s; }
.recipe-item:nth-child(3) { animation-delay: 0.08s; }
.recipe-item:nth-child(4) { animation-delay: 0.12s; }
.recipe-item:nth-child(5) { animation-delay: 0.16s; }

.recipe-thumb {
  width: 160rpx;
  min-height: 160rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.recipe-thumb-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  border: 4rpx solid #807661;
  box-sizing: border-box;
}
.recipe-thumb-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  background: #f2ede2;
}

.recipe-body {
  flex: 1;
  min-width: 0;
}

.recipe-header {
  margin-bottom: 10rpx;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1c15;
  font-family: 'PingFang SC', monospace;
}

.link-indicator {
  font-size: 24rpx;
  margin-left: 8rpx;
}

.recipe-score {
  font-size: 24rpx;
  color: #e6b325;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.recipe-meta {
  margin-bottom: 12rpx;
}

.recipe-ingredients {
  font-size: 24rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.recipe-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  border: 4rpx solid #807661;
  font-family: 'PingFang SC', monospace;
}

.action-btn:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

.rate-btn {
  background: #f3ab72;
  color: #885120;
  box-shadow: 4rpx 4rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: #e6b325;
  color: #5e4700;
  font-size: 48rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #807661;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(255, 255, 255, 0.4), 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
  z-index: 100;
  font-family: 'PingFang SC', monospace;
}

.fab-btn:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(0, 0, 0, 0.1);
}
