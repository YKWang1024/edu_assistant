<view class="container">
  <view class="form-card card">
    <view class="card-title">
      <text class="icon">📝</text>
      <text>菜谱信息</text>
    </view>

    <view class="form-group">
      <text class="form-label">成品照片</text>
      <!-- 编辑模式：原图只读预览(本版编辑暂不支持换图) -->
      <block wx:if="{{editMode}}">
        <view class="image-list" wx:if="{{existingImages.length > 0}}">
          <view class="image-item" wx:for="{{existingImages}}" wx:key="*this">
            <image class="image-thumb" src="{{item}}" mode="aspectFill" bindtap="onPreviewExisting" data-src="{{item}}" />
          </view>
        </view>
        <view class="img-edit-hint">本版编辑暂不换图，图片保持不变</view>
      </block>
      <!-- 新增模式：选图 + 智能识别 -->
      <block wx:else>
        <view class="image-list">
          <view class="image-item" wx:for="{{images}}" wx:key="*this">
            <image class="image-thumb" src="{{item}}" mode="aspectFill" bindtap="onPreviewImage" data-src="{{item}}" />
            <view class="remove-img" data-index="{{index}}" catchtap="onRemoveImage">✕</view>
          </view>
          <view class="image-add" bindtap="onChooseImage" wx:if="{{images.length < 2}}">
            <text class="add-icon">+</text>
            <text class="add-text">{{images.length}}/2</text>
          </view>
        </view>
        <input class="input-field desc-input" placeholder="一句话描述这道菜，识别更准（如：番茄炒蛋，偏甜口）" value="{{desc}}" bindinput="onDescInput" wx:if="{{images.length > 0}}" />
        <button class="btn-secondary analyze-btn" bindtap="onAIRecognize" loading="{{recognizing}}" disabled="{{recognizing}}" wx:if="{{images.length > 0}}">
          🤖 智能识别菜谱（自动填写）
        </button>
      </block>
    </view>

    <view class="calories-card card" wx:if="{{calories}}">
      <view class="calories-header">
        <text class="calories-icon">🔥</text>
        <text class="calories-title">营养信息（智能估算，可不填）</text>
      </view>
      <view class="calories-content">
        <view class="calories-main">
          <text class="calories-value">{{calories.calories}}</text>
          <text class="calories-unit">{{calories.unit}}</text>
        </view>
        <view class="calories-details">
          <view class="detail-item">
            <text class="detail-label">蛋白质</text>
            <text class="detail-value">{{calories.protein}}g</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">脂肪</text>
            <text class="detail-value">{{calories.fat}}g</text>
          </view>
          <view class="detail-item">
            <text class="detail-label">碳水</text>
            <text class="detail-value">{{calories.carbs}}g</text>
          </view>
        </view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">菜名 *</text>
      <input class="input-field" placeholder="例如: 番茄炒蛋" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-group">
      <text class="form-label">食材</text>
      <textarea class="textarea-field" placeholder="食材，用「、」分隔" value="{{ingredients}}" bindinput="onIngredientsInput" auto-height />
    </view>

    <view class="form-group">
      <text class="form-label">做法</text>
      <textarea class="textarea-field" placeholder="做法步骤" value="{{steps}}" bindinput="onStepsInput" auto-height />
    </view>

    <view class="form-group">
      <text class="form-label">分类</text>
      <picker range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="time-picker">
          {{categories[categoryIndex]}}
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label">建议餐次（可多选，可不选）</text>
      <view class="meal-chips">
        <view class="meal-chip {{item.on ? 'on' : ''}}" wx:for="{{mealChips}}" wx:key="label" data-meal="{{item.label}}" bindtap="onToggleMeal">{{item.label}}</view>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">标签</text>
      <input class="input-field" placeholder="例如: 下饭, 简单, 快手菜" value="{{tags}}" bindinput="onTagsInput" />
    </view>

    <view class="form-group">
      <text class="form-label">参考链接</text>
      <input class="input-field" placeholder="粘贴小红书或哔哩哔哩链接" value="{{referenceInput}}" bindinput="onReferenceLinkInput" />
      <view class="link-type-tag" wx:if="{{referenceLabel}}">
        <text class="link-type-icon">{{referenceType === 'xiaohongshu' ? '📕' : referenceType === 'bilibili' ? '📺' : '🔗'}}</text>
        <text class="link-type-text">{{referenceLabel}}</text>
      </view>
    </view>

    <view class="form-group" wx:if="{{nutrition}}">
      <text class="form-label">营养分析</text>
      <view class="nutrition-text">{{nutrition}}</view>
    </view>

    <button class="btn-primary save-btn" bindtap="onSave" loading="{{saving}}" disabled="{{saving}}">{{editMode ? '保存修改' : '保存菜谱'}}</button>
  </view>

  <!-- 离屏 canvas：用于压缩图片 -->
  <canvas type="2d" id="recipeCanvas" style="position:fixed;left:-9999px;top:0;width:10px;height:10px;"></canvas>
</view>
