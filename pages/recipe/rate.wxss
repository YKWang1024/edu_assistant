.rate-header {
  text-align: center;
  padding: 30rpx;
}

.rate-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1c15;
  margin-bottom: 8rpx;
  font-family: 'PingFang SC', monospace;
}

.rate-current {
  font-size: 26rpx;
  color: #e6b325;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.member-card {
  margin-bottom: 16rpx;
}

.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.member-item {
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  background: #f2ede2;
  color: #4e4634;
  border: 4rpx solid #807661;
  transition: all 0.2s;
  font-family: 'PingFang SC', monospace;
  box-shadow: 4rpx 4rpx 0rpx 0rpx rgba(136, 81, 32, 0.15);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.member-item-name {
  font-size: 26rpx;
  font-weight: 700;
}

.member-rated-badge {
  font-size: 20rpx;
  color: #e6b325;
  background: #fef9ed;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  border: 2rpx solid #e6b325;
}

.member-item.active {
  background: #e6b325;
  color: #5e4700;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(255, 255, 255, 0.4);
}

.member-item:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}

.rate-card {
  margin-bottom: 16rpx;
}

.stars-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star {
  font-size: 64rpx;
  color: #d2c5ad;
  transition: all 0.2s;
}

.star.active {
  color: #e6b325;
  text-shadow: 4rpx 4rpx 0rpx rgba(136, 81, 32, 0.2);
}

.score-display {
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #e6b325;
  font-family: 'PingFang SC', monospace;
}

.comment-card {
  margin-bottom: 24rpx;
}

.submit-btn {
  width: 100%;
  margin-bottom: 40rpx;
}
