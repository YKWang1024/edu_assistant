.rate-header { text-align: center; padding: 30rpx; }
.rate-name { font-size: 36rpx; font-weight: 800; color: #2b2b33; margin-bottom: 10rpx; }
.rate-current { font-size: 26rpx; color: #f5a623; font-weight: 700; }

.member-card { margin-bottom: 18rpx; }
.member-list { display: flex; flex-wrap: wrap; gap: 14rpx; }
.member-item {
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  background: #f1f3f7;
  color: #6b6b7a;
  border: none;
  transition: all 0.15s ease;
  box-shadow: none;
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.member-item-name { font-size: 26rpx; font-weight: 700; }
.member-rated-badge {
  font-size: 20rpx;
  color: #d98a2b;
  background: #fdeede;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  border: none;
}
.member-item.active {
  background: linear-gradient(135deg, #f9b94e, #f5a623);
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(245, 166, 35, 0.28);
}
.member-item:active { transform: scale(0.96); }

.rate-card { margin-bottom: 18rpx; }
.stars-row { display: flex; justify-content: center; gap: 18rpx; margin-bottom: 16rpx; }
.star { font-size: 68rpx; color: #e3e7ef; transition: all 0.2s ease; }
.star.active { color: #f5a623; }
.score-display { text-align: center; font-size: 28rpx; font-weight: 700; color: #f5a623; }

.comment-card { margin-bottom: 24rpx; }
.submit-btn { width: 100%; margin-bottom: 40rpx; }
