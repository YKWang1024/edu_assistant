.container { width: 100%; height: 100vh; background: #f3f6fb; }
.loading-container { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; }
.loading-spinner { width: 56rpx; height: 56rpx; border: 6rpx solid #e3e7ef; border-top-color: #4ca85f; border-radius: 50%; animation: spin 0.9s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 28rpx; font-size: 28rpx; color: #a0a0ad; }
.error-container { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60rpx; height: 100vh; }
.error-icon { font-size: 80rpx; margin-bottom: 30rpx; }
.error-text { font-size: 28rpx; color: #6b6b7a; text-align: center; margin-bottom: 40rpx; line-height: 1.6; }
.error-actions { display: flex; gap: 24rpx; }
.action-btn { padding: 20rpx 44rpx; border-radius: 999rpx; font-size: 28rpx; border: none; font-weight: 700; }
.retry-btn { background: linear-gradient(135deg, #6cc06f, #4ca85f); color: #ffffff; }
.copy-btn { background: #f1f3f7; color: #4b4b57; }
