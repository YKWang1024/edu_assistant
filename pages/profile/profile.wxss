.profile-edit { padding: 24rpx 24rpx 60rpx; }
.edit-card { padding: 8rpx 28rpx; }

.avatar-row, .name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
}
.row-label { font-size: 29rpx; font-weight: 600; color: #2b2b33; }
.row-sep { height: 2rpx; background: #f1f3f7; }

.avatar-btn {
  width: 110rpx;
  height: 110rpx;
  padding: 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  line-height: normal;
}
.avatar-btn::after { border: none; }
.avatar-img { width: 110rpx; height: 110rpx; border-radius: 50%; }
.avatar-ph {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #f1f3f7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #b5b5c0;
}

.name-input {
  flex: 1;
  text-align: right;
  font-size: 29rpx;
  color: #2b2b33;
}

.tip { font-size: 22rpx; color: #a0a0ad; line-height: 1.6; margin: 18rpx 6rpx 0; }
.save-btn { width: 100%; margin-top: 36rpx; }
