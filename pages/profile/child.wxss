.page { min-height: 100vh; background: #f3f6fb; padding: 32rpx 28rpx; box-sizing: border-box; }

.avatar-block { display: flex; flex-direction: column; align-items: center; margin: 20rpx 0 36rpx; }
.avatar-img, .avatar-ph {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  box-shadow: 0 10rpx 26rpx rgba(110, 120, 230, 0.22);
}
.avatar-ph {
  background: #eaeef5; display: flex; align-items: center; justify-content: center; font-size: 80rpx;
}
.avatar-edit { margin-top: 16rpx; font-size: 25rpx; color: #4ca85f; }

.form { background: #fff; border-radius: 24rpx; padding: 8rpx 28rpx; }
.form-row { display: flex; align-items: center; padding: 28rpx 0; border-bottom: 2rpx solid #f0f0f4; }
.form-row:last-child { border-bottom: none; }
.form-label { width: 120rpx; font-size: 28rpx; color: #2b2b33; font-weight: 600; }
.form-input { flex: 1; font-size: 28rpx; color: #2b2b33; }

.save-btn {
  margin-top: 44rpx; background: #4ca85f; color: #fff; border: none;
  border-radius: 999rpx; font-size: 30rpx; font-weight: 700; padding: 20rpx 0;
}
.save-btn[disabled] { opacity: 0.6; }
.hint { margin-top: 20rpx; text-align: center; font-size: 23rpx; color: #a0a0ad; }
