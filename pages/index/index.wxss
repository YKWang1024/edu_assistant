.home {
  padding: 24rpx 24rpx 60rpx;
}

/* ---------- 顶部渐变头 ---------- */
.hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #aed4f5 0%, #7fb8f0 55%, #8ea2f0 100%);
  border-radius: 32rpx;
  padding: 36rpx 32rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(110, 150, 220, 0.30);
}
.hero-blob {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  pointer-events: none;
}
.hero-blob-1 { width: 240rpx; height: 240rpx; top: -90rpx; right: -50rpx; }
.hero-blob-2 { width: 160rpx; height: 160rpx; bottom: -70rpx; left: 30rpx; background: rgba(255, 255, 255, 0.12); }

.hero-row {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.hero-user { display: flex; align-items: center; }
.hero-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-right: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(60, 100, 170, 0.25);
}
.hero-hi {
  font-size: 40rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.01em;
  text-shadow: 0 2rpx 6rpx rgba(60, 100, 170, 0.25);
}
.hero-meta {
  margin-top: 8rpx;
  font-size: 25rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
}
.hero-dot { margin: 0 10rpx; opacity: 0.7; }
.hero-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(6rpx);
}
.hero-badge-icon { font-size: 44rpx; }
.hero-badge:active { transform: scale(0.94); }

/* 今日能量 */
.energy {
  position: relative;
  margin-top: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx;
  padding: 24rpx 26rpx;
  box-shadow: 0 8rpx 20rpx rgba(60, 100, 170, 0.14);
}
.energy-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 14rpx;
}
.energy-label { font-size: 26rpx; font-weight: 700; color: #4a5a78; }
.energy-val { font-size: 32rpx; font-weight: 800; color: #f5a623; }
.energy-bar {
  height: 18rpx;
  background: #e8edf6;
  border-radius: 999rpx;
  overflow: hidden;
}
.energy-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd76a, #f5a623);
  border-radius: 999rpx;
  transition: width 0.5s ease;
}
.energy-tip { margin-top: 12rpx; font-size: 22rpx; color: #8a98b2; }

/* ---------- 三大入口 ---------- */
.entry-grid {
  display: flex;
  gap: 18rpx;
  margin-bottom: 28rpx;
}
.entry-card {
  flex: 1;
  border-radius: 28rpx;
  padding: 28rpx 18rpx 24rpx;
  text-align: center;
  box-shadow: 0 10rpx 26rpx rgba(80, 95, 130, 0.10);
  transition: transform 0.12s ease;
}
.entry-card:active { transform: translateY(4rpx) scale(0.98); }
.entry-green { background: linear-gradient(160deg, #e7f6e8 0%, #d3eed6 100%); }
.entry-orange { background: linear-gradient(160deg, #fdf0d9 0%, #fbe3bd 100%); }
.entry-purple { background: linear-gradient(160deg, #efe9fb 0%, #e2d8f8 100%); }
.entry-emoji {
  width: 84rpx;
  height: 84rpx;
  margin: 0 auto 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
}
.entry-title { font-size: 28rpx; font-weight: 800; color: #2f3a2a; }
.entry-orange .entry-title { color: #7a5410; }
.entry-purple .entry-title { color: #4d3a7a; }
.entry-green .entry-title { color: #2f5a32; }
.entry-sub { margin-top: 6rpx; font-size: 21rpx; color: #8a8a8a; }

/* ---------- 一键小测 CTA ---------- */
.quiz-cta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #6cc06f 0%, #4ca85f 100%);
  border-radius: 28rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 14rpx 30rpx rgba(76, 168, 95, 0.30);
  transition: transform 0.12s ease;
}
.quiz-cta:active { transform: scale(0.98); }
.quiz-left { display: flex; align-items: center; }
.quiz-emoji {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
}
.quiz-title { font-size: 32rpx; font-weight: 800; color: #ffffff; }
.quiz-sub { margin-top: 6rpx; font-size: 22rpx; color: rgba(255, 255, 255, 0.88); }
.quiz-go {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.22);
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

/* ---------- 学习练习列表 ---------- */
.func-list { margin-bottom: 8rpx; }

/* 入场动效：只动 opacity，避免覆盖按下位移 */
@keyframes fadeIn { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: translateY(0); } }
.entry-card, .func-item, .quiz-cta, .habit-tile { animation: fadeIn 0.4s ease both; }
.func-item:nth-child(2) { animation-delay: 0.05s; }
.func-item:nth-child(3) { animation-delay: 0.10s; }
.func-item:nth-child(4) { animation-delay: 0.15s; }

.func-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 22rpx rgba(80, 95, 130, 0.07);
  transition: transform 0.12s ease;
}
.func-item:active { transform: scale(0.985); }

.func-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 22rpx;
  flex-shrink: 0;
}
.math-icon { background: #e3f4e0; }
.pinyin-icon { background: #fdeede; }
.english-icon { background: #e2eefe; }
.exam-icon { background: #efe9fb; }
.func-icon { font-size: 42rpx; }

.func-info { flex: 1; min-width: 0; }
.func-name { font-size: 30rpx; font-weight: 700; color: #2b2b33; margin-bottom: 4rpx; }
.func-desc { font-size: 23rpx; color: #9a9aa7; }
.func-arrow { font-size: 40rpx; color: #c6c6d0; font-weight: 300; }

/* ---------- 习惯打卡网格 ---------- */
.habit-grid {
  display: flex;
  gap: 18rpx;
}
.habit-tile {
  flex: 1;
  position: relative;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 0 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(80, 95, 130, 0.07);
  transition: transform 0.12s ease;
}
.habit-tile:active { transform: scale(0.97); }
.habit-tile.done { background: linear-gradient(160deg, #e7f6e8 0%, #d6efd9 100%); }
.habit-tile-icon {
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 12rpx;
  border-radius: 50%;
  background: #f1f4f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.habit-tile.done .habit-tile-icon { background: rgba(255, 255, 255, 0.75); }
.habit-tile-name { font-size: 25rpx; font-weight: 700; color: #5a5a66; }
.habit-tile.done .habit-tile-name { color: #2f5a32; }
.habit-tile-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 36rpx;
  background: transparent;
}
.habit-tile.done .habit-tile-check { background: #4ca85f; box-shadow: 0 4rpx 10rpx rgba(76, 168, 95, 0.4); }
