.balance-card {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: 4rpx solid #807661;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.balance-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #775a00;
}

.balance-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx;
  text-align: center;
}

.balance-label {
  font-size: 26rpx;
  color: #f3ab72;
  margin-bottom: 16rpx;
  font-family: 'PingFang SC', monospace;
}

.balance-value {
  font-size: 72rpx;
  font-weight: 800;
  color: #fef9ed;
  margin-bottom: 24rpx;
  font-family: 'PingFang SC', monospace;
}

.balance-unit {
  font-size: 28rpx;
  font-weight: 400;
  color: #f3ab72;
}

.use-btn {
  display: inline-block;
  background: #e6b325;
  color: #5e4700;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  padding: 12rpx 40rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.5;
  font-family: 'PingFang SC', monospace;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(255, 255, 255, 0.4);
}

.use-btn::after {
  border: none;
}

.use-btn:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(0, 0, 0, 0.1);
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  font-family: 'PingFang SC', monospace;
}

.stat-value.positive {
  color: #47672c;
}

.stat-value.negative {
  color: #885120;
}

.stat-label {
  font-size: 22rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
}

.record-list {
  margin-top: 10rpx;
}

.record-item {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
}

.record-header {
  margin-bottom: 10rpx;
}

.record-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.record-type {
  font-weight: 700;
  font-size: 28rpx;
  color: #1d1c15;
  font-family: 'PingFang SC', monospace;
}

.record-date {
  font-size: 22rpx;
  color: #807661;
  font-family: 'PingFang SC', monospace;
}

.record-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-text {
  font-size: 24rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
}

.detail-reward {
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.detail-reward.positive {
  color: #47672c;
}

.detail-reward.negative {
  color: #885120;
}

.detail-reward.neutral {
  color: #807661;
}
