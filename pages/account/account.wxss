/* ========== 游戏时间钱包 · 柔和风 ========== */
.balance-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  border: none;
  box-shadow: 0 16rpx 36rpx rgba(110, 120, 230, 0.28);
}
.balance-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #8b7af0 0%, #6a8bf0 60%, #5b9ef0 100%);
}
.balance-bg::after {
  content: '';
  position: absolute;
  width: 260rpx; height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
  top: -110rpx; right: -60rpx;
}
.balance-content { position: relative; z-index: 1; padding: 44rpx 30rpx; text-align: center; }
.balance-label { font-size: 26rpx; color: rgba(255, 255, 255, 0.9); margin-bottom: 16rpx; }
.balance-value { font-size: 76rpx; font-weight: 800; color: #ffffff; margin-bottom: 26rpx; }
.balance-unit { font-size: 28rpx; font-weight: 400; color: rgba(255, 255, 255, 0.85); }
.use-btn {
  display: inline-block;
  background: rgba(255, 255, 255, 0.95);
  color: #5b6ff0;
  border: none;
  border-radius: 999rpx;
  padding: 16rpx 50rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.5;
  box-shadow: 0 8rpx 18rpx rgba(60, 70, 160, 0.2);
}
.use-btn::after { border: none; }
.use-btn:active { transform: scale(0.96); }

.stats-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.stat-item { flex: 1; text-align: center; padding: 28rpx 16rpx; }
.stat-value { font-size: 38rpx; font-weight: 800; margin-bottom: 8rpx; color: #2b2b33; }
.stat-value.positive { color: #4ca85f; }
.stat-value.negative { color: #f5a623; }
.stat-label { font-size: 22rpx; color: #a0a0ad; }

.record-list { margin-top: 10rpx; }
.record-item { margin-bottom: 16rpx; padding: 24rpx; }
.record-header { margin-bottom: 12rpx; }
.record-icon { font-size: 28rpx; margin-right: 8rpx; }
.record-type { font-weight: 700; font-size: 28rpx; color: #2b2b33; }
.record-date { font-size: 22rpx; color: #a0a0ad; }
.record-detail { display: flex; justify-content: space-between; align-items: center; }
.detail-text { font-size: 24rpx; color: #8a8a97; }
.detail-reward { font-size: 28rpx; font-weight: 700; }
.detail-reward.positive { color: #4ca85f; }
.detail-reward.negative { color: #f5a623; }
.detail-reward.neutral { color: #a0a0ad; }

/* REQ-003 学习互动 · 每日记录 */
.usage-card { padding: 8rpx 24rpx; margin-bottom: 24rpx; }
.usage-day {
  display: flex; justify-content: space-between; align-items: center;
  padding: 18rpx 0; border-bottom: 1rpx solid #f0f0f4;
}
.usage-day:last-child { border-bottom: none; }
.usage-date { font-size: 26rpx; color: #2b2b33; font-weight: 600; }
.usage-meta { font-size: 24rpx; color: #8a8a97; }
