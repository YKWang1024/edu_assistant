.progress-bar {
  height: 16rpx;
  background: #dedace;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  border: 4rpx solid #807661;
}

.progress-fill {
  height: 100%;
  background: #47672c;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  color: #4e4634;
  font-size: 24rpx;
  margin-bottom: 40rpx;
  font-family: 'PingFang SC', monospace;
  font-weight: 700;
}

.question-card {
  text-align: center;
  padding: 60rpx 30rpx;
  margin-bottom: 40rpx;
}

.question-type-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #fef9ed;
  background: #47672c;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  font-weight: 700;
  border: 2rpx solid #2d441a;
}

.question-text {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.question-content {
  font-size: 48rpx;
  font-weight: 700;
  color: #775a00;
  font-family: 'PingFang SC', monospace;
  display: block;
  margin-bottom: 10rpx;
}

.question-hint {
  font-size: 26rpx;
  color: #807661;
  font-family: 'PingFang SC', monospace;
  display: block;
}

.num {
  font-size: 80rpx;
  font-weight: 700;
  color: #775a00;
  font-family: 'PingFang SC', monospace;
}

.operator {
  font-size: 60rpx;
  font-weight: 700;
  color: #885120;
  margin: 0 8rpx;
  font-family: 'PingFang SC', monospace;
}

.placeholder {
  color: #d2c5ad;
}

.answer-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 0 20rpx;
}

.answer-input {
  flex: 1;
  height: 88rpx;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #1d1c15;
  background: #fef9ed;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
  font-family: 'PingFang SC', monospace;
}

.submit-btn {
  width: 160rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 30rpx;
}

.header-bar {
  margin-bottom: 20rpx;
}

.wrong-count {
  font-size: 26rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
  font-weight: 700;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-text {
  font-size: 26rpx;
  color: #775a00;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
  padding: 8rpx 20rpx;
  background: #f2ede2;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #e7e2d6, inset -4rpx -4rpx 0rpx 0rpx #807661;
}

.action-text:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #807661, inset -4rpx -4rpx 0rpx 0rpx #e7e2d6;
}

.action-text.danger {
  color: #ba1a1a;
  background: #ffdad6;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(255, 218, 214, 0.6), inset -4rpx -4rpx 0rpx 0rpx #ba1a1a;
}

.action-text.danger:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #ba1a1a, inset -4rpx -4rpx 0rpx 0rpx rgba(255, 218, 214, 0.6);
}

.wrong-item {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
}

.wrong-header {
  margin-bottom: 10rpx;
}

.wrong-header .question-type-tag {
  margin-bottom: 8rpx;
}

.wrong-question {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d1c15;
  font-family: 'PingFang SC', monospace;
}

.wrong-question .q-text {
  display: block;
  margin-bottom: 6rpx;
}

.wrong-question .a-text {
  display: block;
  font-size: 28rpx;
  color: #47672c;
}

.wrong-count-badge {
  font-size: 22rpx;
  color: #885120;
  background: #f3ab72;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-weight: 700;
  border: 2rpx solid #807661;
  font-family: 'PingFang SC', monospace;
}

.wrong-footer {
  padding-top: 6rpx;
}

.wrong-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wrong-date {
  font-size: 22rpx;
  color: #807661;
  font-family: 'PingFang SC', monospace;
}

.delete-btn {
  font-size: 24rpx;
  color: #ba1a1a;
  padding: 4rpx 16rpx;
  background: #ffdad6;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(255, 218, 214, 0.6), inset -4rpx -4rpx 0rpx 0rpx #ba1a1a;
}

.delete-btn:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #ba1a1a, inset -4rpx -4rpx 0rpx 0rpx rgba(255, 218, 214, 0.6);
}
