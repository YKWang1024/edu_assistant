.progress-bar {
  height: 16rpx;
  background: #e9edf4;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  border: none;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #a78bfa, #8b6fd6);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}
.progress-text {
  text-align: center;
  color: #6b6b7a;
  font-size: 24rpx;
  margin-bottom: 36rpx;
  font-weight: 700;
}

.question-card { text-align: center; padding: 60rpx 30rpx; margin-bottom: 36rpx; }
.question-type-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #8b6fd6;
  background: #efe9fb;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  margin-bottom: 22rpx;
  font-weight: 700;
  border: none;
}
.question-text { display: flex; align-items: center; justify-content: center; gap: 16rpx; }
.question-content { font-size: 46rpx; font-weight: 800; color: #2b2b33; display: block; margin-bottom: 10rpx; }
.question-hint { font-size: 26rpx; color: #a0a0ad; display: block; }
.num { font-size: 80rpx; font-weight: 800; color: #2b2b33; }
.operator { font-size: 60rpx; font-weight: 800; color: #8b6fd6; margin: 0 8rpx; }
.placeholder { color: #c6c6d0; }

.answer-area { display: flex; align-items: center; gap: 20rpx; padding: 0 20rpx; }
.answer-input {
  flex: 1;
  height: 92rpx;
  border: 2rpx solid #eceef4;
  border-radius: 18rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #2b2b33;
  background: #f7f8fb;
}
.submit-btn { width: 170rpx; height: 92rpx; line-height: 92rpx; padding: 0; font-size: 30rpx; }

.header-bar { margin-bottom: 22rpx; }
.wrong-count { font-size: 26rpx; color: #6b6b7a; font-weight: 700; }
.header-actions { display: flex; gap: 16rpx; }
.action-text {
  font-size: 25rpx;
  color: #8b6fd6;
  font-weight: 700;
  padding: 12rpx 26rpx;
  background: #efe9fb;
  border: none;
  border-radius: 999rpx;
}
.action-text:active { transform: scale(0.96); }
.action-text.danger { color: #e5484d; background: #ffe9e6; }

@keyframes wrongIn { from { opacity: 0; transform: translateY(12rpx); } to { opacity: 1; transform: translateY(0); } }
.wrong-item { margin-bottom: 16rpx; padding: 24rpx; animation: wrongIn 0.32s ease both; }
.wrong-item:nth-child(2) { animation-delay: 0.04s; }
.wrong-item:nth-child(3) { animation-delay: 0.08s; }
.wrong-header { margin-bottom: 12rpx; }
.wrong-header .question-type-tag { margin-bottom: 10rpx; }
.wrong-question { font-size: 32rpx; font-weight: 700; color: #2b2b33; }
.wrong-question .q-text { display: block; margin-bottom: 6rpx; }
.wrong-question .a-text { display: block; font-size: 28rpx; color: #4ca85f; }

.wrong-count-badge {
  font-size: 22rpx;
  color: #d98a2b;
  background: #fdeede;
  padding: 5rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 700;
  border: none;
}
.wrong-footer { padding-top: 8rpx; }
.wrong-info { display: flex; align-items: center; gap: 14rpx; }
.wrong-date { font-size: 22rpx; color: #a0a0ad; }
.delete-btn {
  font-size: 24rpx;
  color: #e5484d;
  padding: 8rpx 22rpx;
  background: #ffe9e6;
  border: none;
  border-radius: 999rpx;
  font-weight: 700;
}
.delete-btn:active { transform: scale(0.95); }
