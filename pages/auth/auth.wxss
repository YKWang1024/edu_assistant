.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #fef9ed 0%, #f2ede2 100%);
}

.auth-card {
  background: #fef9ed;
  border: 4rpx solid #807661;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.auth-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #775a00;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #807661;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #4e4634;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  background: #fef9ed;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
}

.avatar-upload {
  width: 200rpx;
  height: 200rpx;
  border: 4rpx dashed #807661;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.upload-icon {
  font-size: 48rpx;
}

.upload-text {
  font-size: 22rpx;
  color: #807661;
}

.auth-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.switch-mode {
  text-align: center;
  font-size: 26rpx;
  color: #775a00;
  padding: 16rpx;
}

.switch-mode:active {
  opacity: 0.7;
}