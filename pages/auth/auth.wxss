.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #eaf3fb 0%, #f3f6fb 100%);
}

.auth-card {
  background: #ffffff;
  border: none;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(80, 95, 130, 0.10);
}

.auth-header { text-align: center; margin-bottom: 40rpx; }
.title { font-size: 48rpx; font-weight: 800; color: #2b2b33; margin-bottom: 10rpx; letter-spacing: -0.02em; }
.subtitle { font-size: 26rpx; color: #a0a0ad; }

.form-group { margin-bottom: 30rpx; }
.form-label { font-size: 28rpx; color: #6b6b7a; margin-bottom: 12rpx; font-weight: 600; }
.form-input {
  width: 100%;
  height: 92rpx;
  border: 2rpx solid #eceef4;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  background: #f7f8fb;
  box-sizing: border-box;
}

.avatar-upload {
  width: 200rpx;
  height: 200rpx;
  border: 3rpx dashed #cdd2dc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #f7f8fb;
}
.avatar-preview { width: 100%; height: 100%; object-fit: cover; }
.avatar-placeholder { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.upload-icon { font-size: 48rpx; }
.upload-text { font-size: 22rpx; color: #a0a0ad; }

.auth-btn { width: 100%; height: 96rpx; line-height: 96rpx; font-size: 32rpx; margin-bottom: 20rpx; }
.switch-mode { text-align: center; font-size: 26rpx; color: #4ca85f; padding: 16rpx; font-weight: 600; }
.switch-mode:active { opacity: 0.7; }
