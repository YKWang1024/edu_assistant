<view class="container">
  <view wx:if="{{loading}}" class="empty-tip">加载中…</view>

  <view wx:elif="{{needLogin}}" class="card login-card">
    <view class="login-text">需要先登录/注册才能管理家庭</view>
    <button class="btn-primary" bindtap="onGoAuth">去登录 / 注册</button>
  </view>

  <block wx:else>
    <view class="card">
      <view class="card-title flex-between">
        <view><text class="icon">👨‍👩‍👧</text>家庭成员（{{members.length}}）</view>
        <text class="rename-link" bindtap="onRename">改我的称呼</text>
      </view>
      <view class="member-item" wx:for="{{members}}" wx:key="openid" data-member="{{item}}" bindtap="{{isAdmin && !item.isMe ? 'onChangeRole' : ''}}">
        <text class="member-name">{{item.displayName}}{{item.isMe ? '（我）' : ''}}</text>
        <text class="member-role {{item.role === 'admin' ? 'admin' : (item.role === 'observer' ? 'observer' : '')}}">{{item.roleLabel}}</text>
        <text wx:if="{{isAdmin && !item.isMe}}" class="member-edit">改角色 ›</text>
      </view>
      <view wx:if="{{isAdmin}}" class="card-hint">点成员可设为 管理员 / 成员 / 旁观者(只读)。</view>
    </view>

    <!-- 无账号小孩成员（妹妹/姐姐等）-->
    <view class="card">
      <view class="card-title flex-between">
        <view><text class="icon">🧒</text>小孩（{{children.length}}）</view>
        <text wx:if="{{isAdmin}}" class="rename-link" bindtap="onAddChild">+ 添加小孩</text>
      </view>
      <view wx:if="{{children.length === 0}}" class="card-hint">还没有小孩成员。{{isAdmin ? '点右上角添加（无需小程序账号），可记录他/她的错题、年级、菜谱评分。' : ''}}</view>
      <view class="member-item" wx:for="{{children}}" wx:key="childId">
        <text class="member-name">{{item.name}}</text>
        <text class="child-grade" wx:if="{{item.grade}}">{{item.grade}}</text>
        <view wx:if="{{isAdmin}}" class="child-actions">
          <text class="member-edit" data-child="{{item}}" catchtap="onEditChild">编辑</text>
          <text class="member-edit danger" data-child="{{item}}" catchtap="onRemoveChild">移除</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title"><text class="icon">🔑</text>我的家庭码</view>
      <view class="code-box">
        <text class="code-text">{{inviteCode || '生成中…'}}</text>
      </view>
      <view class="code-actions">
        <button class="btn-secondary code-btn" bindtap="onCopyCode">复制</button>
        <button class="btn-primary code-btn" open-type="share">转发卡片</button>
        <button wx:if="{{isAdmin}}" class="btn-secondary code-btn" bindtap="onGenerateCode">重新生成</button>
      </view>
      <view class="code-hint">把这个家庭码或卡片发给家人，对方在下方「输入邀请码加入」即可加入你的家庭。邀请码 7 天有效。</view>
    </view>

    <view class="card join-other">
      <view class="join-text">想加入别人的家庭？</view>
      <button class="btn-secondary" bindtap="onGoJoin">输入邀请码加入</button>
    </view>
  </block>
</view>
