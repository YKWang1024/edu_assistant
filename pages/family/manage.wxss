.login-card { text-align: center; padding: 60rpx 40rpx; }
.login-text { font-size: 28rpx; color: #6b6b7a; margin-bottom: 30rpx; }

.member-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 6rpx;
  border-bottom: 2rpx solid #f1f3f7;
}
.member-item:last-child { border-bottom: none; }
.member-name { font-size: 30rpx; font-weight: 700; color: #2b2b33; }
.member-role {
  font-size: 22rpx;
  color: #6b6b7a;
  background: #f1f3f7;
  border: none;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  font-weight: 700;
}
.member-role.admin { color: #b07a00; background: #fff3d6; }
.member-role.observer { color: #4b86ef; background: #e2eefe; }
.member-edit { font-size: 22rpx; color: #4ca85f; font-weight: 700; margin-left: 14rpx; }
.member-edit.danger { color: #e5484d; }
.child-grade {
  font-size: 22rpx;
  color: #3f8d57;
  background: #e3f4e0;
  border: none;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  font-weight: 700;
  margin-left: auto;
  margin-right: 10rpx;
}
.child-actions { display: flex; align-items: center; }

.rename-link { font-size: 24rpx; color: #4ca85f; font-weight: 700; }
.card-hint { font-size: 24rpx; color: #a0a0ad; line-height: 1.55; padding: 10rpx 4rpx 0; }

.code-box {
  text-align: center;
  background: #f7f8fb;
  border: 3rpx dashed #cdd2dc;
  border-radius: 18rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.code-text { font-size: 56rpx; font-weight: 800; letter-spacing: 8rpx; color: #5b6ff0; }
.code-actions { display: flex; gap: 16rpx; }
.code-btn { flex: 1; padding: 18rpx 0; font-size: 26rpx; }
.code-hint { font-size: 24rpx; color: #a0a0ad; margin-top: 16rpx; line-height: 1.55; }

.join-other { text-align: center; }
.join-text { font-size: 26rpx; color: #6b6b7a; margin-bottom: 18rpx; }
