.login-card {
  text-align: center;
  padding: 60rpx 40rpx;
}
.login-text {
  font-size: 28rpx;
  color: #4e4634;
  margin-bottom: 30rpx;
}

.member-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 8rpx;
  border-bottom: 2rpx solid #ece5d6;
}
.member-item:last-child {
  border-bottom: none;
}
.member-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1c15;
  font-family: 'PingFang SC', monospace;
}
.member-role {
  font-size: 22rpx;
  color: #4e4634;
  background: #f2ede2;
  border: 2rpx solid #807661;
  border-radius: 4rpx;
  padding: 4rpx 14rpx;
  font-weight: 700;
}
.member-role.admin {
  color: #5e4700;
  background: #e6b325;
}

.rename-link {
  font-size: 24rpx;
  color: #775a00;
  font-weight: 700;
}

.code-box {
  text-align: center;
  background: #fef9ed;
  border: 4rpx dashed #807661;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.code-text {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  color: #775a00;
  font-family: 'PingFang SC', monospace;
}
.code-actions {
  display: flex;
  gap: 16rpx;
}
.code-btn {
  flex: 1;
  padding: 16rpx 0;
  font-size: 26rpx;
}
.code-hint {
  font-size: 24rpx;
  color: #807661;
  margin-top: 16rpx;
  line-height: 1.5;
}

.join-other {
  text-align: center;
}
.join-text {
  font-size: 26rpx;
  color: #4e4634;
  margin-bottom: 18rpx;
}
