.field-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #5e4700;
  margin: 16rpx 0 12rpx;
  font-family: 'PingFang SC', monospace;
}
.code-input {
  letter-spacing: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
}
.from-card-tip {
  font-size: 26rpx;
  color: #47672c;
  background: #c7efa4;
  border: 2rpx solid #47672c;
  border-radius: 8rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 12rpx;
  line-height: 1.5;
}
.join-btn {
  width: 100%;
  margin-top: 28rpx;
}
.join-hint {
  font-size: 24rpx;
  color: #807661;
  text-align: center;
  margin-top: 18rpx;
  line-height: 1.5;
}
