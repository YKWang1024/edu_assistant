.field-label { font-size: 26rpx; font-weight: 700; color: #6b6b7a; margin: 18rpx 0 12rpx; }
.code-input { letter-spacing: 8rpx; font-size: 36rpx; font-weight: 700; text-align: center; }
.from-card-tip {
  font-size: 26rpx;
  color: #3f8d57;
  background: #e8f6e7;
  border: none;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  line-height: 1.55;
}
.join-btn { width: 100%; margin-top: 28rpx; }
.join-hint { font-size: 24rpx; color: #a0a0ad; text-align: center; margin-top: 18rpx; line-height: 1.55; }
