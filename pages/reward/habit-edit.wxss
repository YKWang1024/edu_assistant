.page { min-height: 100vh; background: #f3f6fb; padding: 24rpx; box-sizing: border-box; }
.form-card { padding: 28rpx 24rpx; }

.form-group { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 28rpx; color: #6b6b7a; margin-bottom: 12rpx; font-weight: 700; }
.time-picker {
  display: flex; justify-content: space-between; align-items: center;
  border: 2rpx solid #eceef4; border-radius: 16rpx; padding: 24rpx;
  font-size: 30rpx; color: #2b2b33; background: #f7f8fb;
}
.picker-arrow { font-size: 20rpx; color: #a0a0ad; }

.cycle-switch { display: flex; align-items: center; gap: 14rpx; font-size: 25rpx; color: #a0a0ad; }
.cycle-switch .on { color: #4ca85f; font-weight: 700; }

.save-btn { width: 100%; margin-top: 12rpx; }
