.tab-bar {
  display: flex;
  background: #fef9ed;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 0;
  border-radius: 8rpx;
  transition: all 0.15s;
  font-family: 'PingFang SC', monospace;
}

.tab-item.active {
  background: #e6b325;
  color: #5e4700;
  border: 4rpx solid #807661;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(255, 255, 255, 0.4), 4rpx 4rpx 0rpx 0rpx rgba(136, 81, 32, 0.15);
  padding: 14rpx 0;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.tab-name {
  font-size: 24rpx;
  font-weight: 700;
}

.rule-card {
  border-left: 8rpx solid #775a00;
}

.target-time {
  font-size: 28rpx;
  color: #4e4634;
  margin-bottom: 12rpx;
  font-family: 'PingFang SC', monospace;
}

.highlight {
  color: #775a00;
  font-weight: 700;
  font-size: 32rpx;
  font-family: 'PingFang SC', monospace;
}

.rule-text {
  font-size: 24rpx;
  color: #4e4634;
  line-height: 1.8;
  white-space: pre-line;
  font-family: 'PingFang SC', monospace;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #4e4634;
  margin-bottom: 12rpx;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.time-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  color: #1d1c15;
  background: #fef9ed;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
  font-family: 'PingFang SC', monospace;
}

.picker-arrow {
  font-size: 20rpx;
  color: #807661;
}

.checkin-btn {
  width: 100%;
  margin-top: 10rpx;
}

/* 切页签按下反馈 + 卡片淡入，和全站一致 */
.tab-item:active { transform: translate(2rpx, 2rpx); }
@keyframes rewardIn { from { opacity: 0; } to { opacity: 1; } }
.rule-card, .checkin-card, .done-card, .result-card {
  animation: rewardIn 0.35s ease both;
}

.done-info {
  padding: 10rpx 0;
}

.done-row {
  padding: 12rpx 0;
}

.done-label {
  color: #4e4634;
  font-size: 26rpx;
  font-family: 'PingFang SC', monospace;
}

.done-value {
  font-weight: 700;
  font-size: 28rpx;
  font-family: 'PingFang SC', monospace;
}

.done-value.positive {
  color: #47672c;
}

.done-value.negative {
  color: #885120;
}

.result-card {
  text-align: center;
  padding: 30rpx;
}

.result-msg {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  font-family: 'PingFang SC', monospace;
}

.result-msg.early {
  color: #47672c;
}

.result-msg.late {
  color: #885120;
}

.result-msg.ontime {
  color: #775a00;
}

.result-total {
  font-size: 26rpx;
  color: #4e4634;
  font-family: 'PingFang SC', monospace;
}

.record-link {
  text-align: center;
  padding: 30rpx;
  color: #775a00;
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  background: #f2ede2;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.record-link:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: none;
}
