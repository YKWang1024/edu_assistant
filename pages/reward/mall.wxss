.page { min-height: 100vh; background: #f3f6fb; padding: 24rpx; box-sizing: border-box; }
.empty-tip { text-align: center; color: #a0a0ad; font-size: 25rpx; padding: 30rpx 0; }

.balance-card {
  text-align: center; padding: 40rpx 0; margin-bottom: 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #8b7af0 0%, #6a8bf0 60%, #5b9ef0 100%);
  box-shadow: 0 12rpx 28rpx rgba(110, 120, 230, 0.28);
}
.balance-label { font-size: 26rpx; color: rgba(255,255,255,0.9); margin-bottom: 12rpx; }
.balance-value { font-size: 68rpx; font-weight: 800; color: #fff; }

.add-link { font-size: 25rpx; color: #5b6ff0; font-weight: 600; }

.catalog-list, .redemption-list { display: flex; flex-direction: column; gap: 14rpx; margin-bottom: 10rpx; }
.catalog-item { padding: 22rpx; }
.catalog-top { display: flex; align-items: center; gap: 16rpx; }
.catalog-icon { font-size: 44rpx; }
.catalog-info { flex: 1; min-width: 0; }
.catalog-name { font-size: 28rpx; font-weight: 700; color: #2b2b33; }
.catalog-desc { font-size: 23rpx; color: #a0a0ad; margin-top: 4rpx; }
.catalog-cost { font-size: 26rpx; font-weight: 700; color: #4ca85f; flex-shrink: 0; }
.catalog-cost.insufficient { color: #c9cede; }
.catalog-ops { display: flex; gap: 22rpx; margin-top: 14rpx; padding-top: 14rpx; border-top: 2rpx solid #f0f0f4; }
.catalog-op { font-size: 24rpx; color: #5b6ff0; }
.catalog-op.danger { color: #e5484d; }

.redemption-item { padding: 18rpx 22rpx; display: flex; align-items: center; gap: 16rpx; }
.redemption-icon { font-size: 32rpx; }
.redemption-info { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.redemption-name { font-size: 26rpx; color: #2b2b33; }
.redemption-cost { font-size: 24rpx; color: #e5484d; font-weight: 600; }
