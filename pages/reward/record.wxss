.record-item { margin-bottom: 18rpx; }
.record-header { margin-bottom: 8rpx; }
.record-icon { font-size: 32rpx; margin-right: 10rpx; }
.record-type { font-weight: 700; font-size: 30rpx; color: #2b2b33; }
.record-date { font-size: 24rpx; color: #a0a0ad; }
.record-body { padding-top: 8rpx; }
.record-row { padding: 10rpx 0; border-bottom: 2rpx solid #f4f6fa; }
.record-row:last-child { border-bottom: none; }
.record-label { font-size: 26rpx; color: #8a8a97; }
.record-value { font-size: 28rpx; font-weight: 700; color: #2b2b33; }
.record-value.positive { color: #4ca85f; }
.record-value.negative { color: #f5a623; }
