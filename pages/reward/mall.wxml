<view class="page">
  <view class="balance-card">
    <view class="balance-label">🌟 我的积分</view>
    <view class="balance-value">{{pointsBalance}}</view>
  </view>

  <view class="section-title flex-between">
    <text>可兑换奖励</text>
    <view class="add-link" wx:if="{{isAdmin}}" bindtap="onAddItem">＋ 添加</view>
  </view>

  <view class="empty-tip" wx:if="{{catalog.length === 0}}">
    还没有可兑换的奖励{{isAdmin ? '，点上方添加' : '，等家长添加'}}
  </view>

  <view class="catalog-list">
    <view class="catalog-item card" wx:for="{{catalog}}" wx:key="_id">
      <view class="catalog-top" data-item="{{item}}" bindtap="onRedeem">
        <text class="catalog-icon">{{item.icon || '🎁'}}</text>
        <view class="catalog-info">
          <view class="catalog-name">{{item.name}}</view>
          <view class="catalog-desc" wx:if="{{item.description}}">{{item.description}}</view>
        </view>
        <view class="catalog-cost {{pointsBalance < item.pointsCost ? 'insufficient' : ''}}">{{item.pointsCost}} 积分</view>
      </view>
      <view class="catalog-ops" wx:if="{{isAdmin}}">
        <text class="catalog-op" data-item="{{item}}" catchtap="onEditItem">编辑</text>
        <text class="catalog-op danger" data-item="{{item}}" catchtap="onDeleteItem">删除</text>
      </view>
    </view>
  </view>

  <view class="section-title">兑换记录</view>
  <view class="empty-tip" wx:if="{{redemptions.length === 0}}">暂无兑换记录</view>
  <view class="redemption-list">
    <view class="redemption-item card" wx:for="{{redemptions}}" wx:key="_id">
      <text class="redemption-icon">{{item.itemIcon || '🎁'}}</text>
      <view class="redemption-info">
        <view class="redemption-name">{{item.itemName}}</view>
        <view class="redemption-cost">- {{item.pointsCost}} 积分</view>
      </view>
    </view>
  </view>
</view>
