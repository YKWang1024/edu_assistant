.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx 30rpx;
}

.result-card {
  width: 100%;
  box-sizing: border-box;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 50rpx 40rpx 56rpx;
  text-align: center;
  border: none;
  box-shadow: 0 14rpx 36rpx rgba(80, 95, 130, 0.10);
  margin-bottom: 40rpx;
}
.result-emoji { font-size: 80rpx; margin-bottom: 16rpx; }

/* 成绩环 */
.score-ring {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  margin: 6rpx auto 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.6s ease;
}
.score-ring-inner {
  width: 216rpx;
  height: 216rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 10rpx rgba(80, 95, 130, 0.06);
}
.score-pct { font-size: 84rpx; font-weight: 800; line-height: 1; letter-spacing: -0.02em; }
.score-unit { font-size: 28rpx; font-weight: 700; margin-left: 4rpx; }
.score-frac { font-size: 24rpx; color: #a0a0ad; margin-top: 10rpx; }

.result-msg { font-size: 32rpx; color: #2b2b33; margin-bottom: 12rpx; font-weight: 700; }
.result-time { font-size: 26rpx; color: #a0a0ad; }

.reward-card {
  width: 100%;
  box-sizing: border-box;
  margin: 0 0 28rpx;
  padding: 30rpx 24rpx;
  text-align: center;
  background: linear-gradient(160deg, #e7f6e8 0%, #d3eed6 100%);
  border: none;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(76, 168, 95, 0.16);
  animation: rewardPop 0.4s ease;
}
.reward-card.zero { background: linear-gradient(160deg, #fdf0d9 0%, #fbe3bd 100%); box-shadow: 0 10rpx 26rpx rgba(245, 166, 35, 0.14); }
@keyframes rewardPop { 0% { transform: scale(0.85); opacity: 0; } 70% { transform: scale(1.04); } 100% { transform: scale(1); opacity: 1; } }
.reward-main { font-size: 32rpx; font-weight: 800; color: #2f5a32; }
.reward-card.zero .reward-main { color: #7a5410; }
.reward-sub { font-size: 24rpx; color: #4a7a4d; margin-top: 10rpx; }
.reward-card.zero .reward-sub { color: #a07a30; }

.btn-group { width: 100%; display: flex; flex-direction: column; gap: 20rpx; }
.btn-group button { width: 100% !important; }
