.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx 30rpx;
}

.reward-card {
  width: 100%;
  box-sizing: border-box;
  margin: 24rpx 0 8rpx;
  padding: 28rpx 24rpx;
  text-align: center;
  background: #c7efa4;
  border: 4rpx solid #47672c;
  border-radius: 16rpx;
  box-shadow: 6rpx 6rpx 0rpx 0rpx rgba(45, 68, 26, 0.2);
  animation: rewardPop 0.4s ease;
}
.reward-card.zero {
  background: #fbf0cf;
  border-color: #807661;
  box-shadow: 6rpx 6rpx 0rpx 0rpx rgba(136, 81, 32, 0.15);
}
@keyframes rewardPop {
  0% { transform: scale(0.85); opacity: 0; }
  70% { transform: scale(1.04); }
  100% { transform: scale(1); opacity: 1; }
}
.reward-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #0c2000;
  font-family: 'PingFang SC', monospace;
}
.reward-card.zero .reward-main { color: #5e4700; }
.reward-sub {
  font-size: 24rpx;
  color: #2d441a;
  margin-top: 10rpx;
}
.reward-card.zero .reward-sub { color: #775a00; }

.result-card {
  width: 100%;
  background: #fef9ed;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  border: 4rpx solid #807661;
  box-shadow: 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
  margin-bottom: 60rpx;
  font-family: 'PingFang SC', monospace;
}

.result-card.perfect {
  background: #fef9ed;
  border-color: #e6b325;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(230, 179, 37, 0.15), 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.result-card.great {
  background: #fef9ed;
  border-color: #47672c;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(71, 103, 44, 0.1), 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.result-card.good {
  background: #fef9ed;
  border-color: #885120;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx rgba(136, 81, 32, 0.1), 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.result-card.tryagain {
  background: #fef9ed;
  border-color: #807661;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad, 8rpx 8rpx 0rpx 0rpx rgba(136, 81, 32, 0.2);
}

.result-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.result-score {
  font-size: 72rpx;
  font-weight: 800;
  color: #775a00;
  margin-bottom: 16rpx;
  font-family: 'PingFang SC', monospace;
}

.result-msg {
  font-size: 32rpx;
  color: #775a00;
  margin-bottom: 12rpx;
  font-weight: 700;
  font-family: 'PingFang SC', monospace;
}

.result-time {
  font-size: 26rpx;
  color: #807661;
  font-family: 'PingFang SC', monospace;
}

.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-group button {
  width: 100% !important;
}
