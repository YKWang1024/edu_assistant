/* ========== AI 讲解 · 柔和风 ========== */
.q-recap { padding: 26rpx 28rpx; background: linear-gradient(160deg, #ffffff 0%, #f6f3fd 100%); }
.recap-label { font-size: 24rpx; font-weight: 700; color: #8b6fd6; margin-bottom: 12rpx; }
.recap-stem { font-size: 30rpx; font-weight: 700; color: #2b2b33; line-height: 1.6; }
.recap-opt { font-size: 26rpx; color: #6b6b7a; margin-top: 8rpx; }
.recap-answer { font-size: 26rpx; font-weight: 700; color: #4ca85f; margin-top: 14rpx; }

.error-card { text-align: center; padding: 44rpx 24rpx; }
.error-text { font-size: 28rpx; color: #e5484d; margin-bottom: 24rpx; }

.course-card { padding: 28rpx; }
.course-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  border-bottom: 2rpx solid #f1f3f7;
  padding-bottom: 16rpx;
}
.course-title { font-size: 30rpx; font-weight: 800; color: #2b2b33; }
.course-status { font-size: 22rpx; color: #a0a0ad; }
.course-text { font-size: 29rpx; color: #2b2b33; line-height: 1.85; white-space: pre-wrap; word-break: break-word; }
.course-cursor { color: #8b6fd6; font-weight: 700; }
.regen-btn { width: 100%; margin-top: 24rpx; }
