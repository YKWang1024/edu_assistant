<view class="container">

  <!-- 1. 选图 -->
  <view wx:if="{{stage === 'pick'}}" class="pick-stage">
    <view class="card pick-card">
      <view class="pick-emoji">📷</view>
      <view class="pick-title">拍照识题</view>
      <view class="pick-tip">给试卷上的一道题拍照或从相册选择，框选题目区域后由 AI 自动识别录入错题本。</view>
      <button class="btn-primary pick-btn" bindtap="onChoose">拍照 / 选择图片</button>
    </view>
  </view>

  <!-- 2. 裁剪 -->
  <view wx:if="{{stage === 'crop'}}" class="crop-stage-wrap">
    <view class="crop-hint">拖动裁剪框，框住一道题目</view>
    <view class="crop-stage" style="width:{{imgBox.width}}px;height:{{imgBox.height}}px">
      <image class="crop-img" src="{{imgSrc}}" style="width:{{imgBox.width}}px;height:{{imgBox.height}}px" mode="scaleToFill"></image>

      <!-- 四周遮罩 -->
      <view class="crop-mask" style="left:{{mask.top.left}}px;top:{{mask.top.top}}px;width:{{mask.top.w}}px;height:{{mask.top.h}}px"></view>
      <view class="crop-mask" style="left:{{mask.bottom.left}}px;top:{{mask.bottom.top}}px;width:{{mask.bottom.w}}px;height:{{mask.bottom.h}}px"></view>
      <view class="crop-mask" style="left:{{mask.left.left}}px;top:{{mask.left.top}}px;width:{{mask.left.w}}px;height:{{mask.left.h}}px"></view>
      <view class="crop-mask" style="left:{{mask.right.left}}px;top:{{mask.right.top}}px;width:{{mask.right.w}}px;height:{{mask.right.h}}px"></view>

      <!-- 裁剪框主体(可拖动) -->
      <view class="crop-box" style="left:{{crop.left}}px;top:{{crop.top}}px;width:{{crop.width}}px;height:{{crop.height}}px"
        data-handle="move" catchtouchstart="onCropTouchStart" catchtouchmove="onCropTouchMove" catchtouchend="onCropTouchEnd">
      </view>

      <!-- 四角手柄 -->
      <view class="crop-handle" style="left:{{crop.left - 14}}px;top:{{crop.top - 14}}px"
        data-handle="tl" catchtouchstart="onCropTouchStart" catchtouchmove="onCropTouchMove" catchtouchend="onCropTouchEnd"></view>
      <view class="crop-handle" style="left:{{crop.left + crop.width - 14}}px;top:{{crop.top - 14}}px"
        data-handle="tr" catchtouchstart="onCropTouchStart" catchtouchmove="onCropTouchMove" catchtouchend="onCropTouchEnd"></view>
      <view class="crop-handle" style="left:{{crop.left - 14}}px;top:{{crop.top + crop.height - 14}}px"
        data-handle="bl" catchtouchstart="onCropTouchStart" catchtouchmove="onCropTouchMove" catchtouchend="onCropTouchEnd"></view>
      <view class="crop-handle" style="left:{{crop.left + crop.width - 14}}px;top:{{crop.top + crop.height - 14}}px"
        data-handle="br" catchtouchstart="onCropTouchStart" catchtouchmove="onCropTouchMove" catchtouchend="onCropTouchEnd"></view>
    </view>
    <view class="crop-actions">
      <button class="btn-secondary crop-action-btn" bindtap="onRetake">重新选图</button>
      <button class="btn-primary crop-action-btn" bindtap="onConfirmCrop">确认并识别</button>
    </view>
  </view>

  <!-- 3. 识别中 -->
  <view wx:if="{{stage === 'recognizing'}}" class="loading-stage">
    <view class="card loading-card">
      <view class="loading-emoji">🤖</view>
      <view class="loading-text">AI 正在识别题目…</view>
    </view>
  </view>

  <!-- 4. 编辑确认 -->
  <view wx:if="{{stage === 'edit' || stage === 'saving'}}" class="edit-stage">
    <image wx:if="{{croppedTempPath}}" class="edit-preview" src="{{croppedTempPath}}" mode="widthFix"></image>

    <view class="card">
      <view class="field-label">科目</view>
      <picker mode="selector" range="{{subjects}}" value="{{form.subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-value">{{form.subject}} ▾</view>
      </picker>

      <view class="field-label">题型</view>
      <picker mode="selector" range="{{typeLabels}}" value="{{form.typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">{{typeLabels[form.typeIndex]}} ▾</view>
      </picker>

      <view class="field-label">题干</view>
      <textarea class="textarea-field" value="{{form.stem}}" bindinput="onStemInput" placeholder="题目内容" auto-height></textarea>

      <block wx:if="{{form.type === 'choice'}}">
        <view class="field-label">选项（点击「设为正确」标记答案）</view>
        <view class="opt-row" wx:for="{{form.options}}" wx:key="key">
          <view class="opt-key">{{item.key}}</view>
          <input class="opt-input" value="{{item.text}}" data-index="{{index}}" bindinput="onOptionInput" placeholder="选项内容" />
          <view class="opt-correct {{form.correctAnswer === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="onSetCorrect">{{form.correctAnswer === item.key ? '✓正确' : '设为正确'}}</view>
          <view class="opt-del" data-index="{{index}}" bindtap="onRemoveOption">✕</view>
        </view>
        <view class="opt-add" bindtap="onAddOption">+ 添加选项</view>
      </block>

      <block wx:else>
        <view class="field-label">正确答案（可留空，复习时自评）</view>
        <input class="input-field" value="{{form.correctAnswer}}" bindinput="onCorrectInput" placeholder="正确答案" />
      </block>

      <view class="field-label">解析（可选）</view>
      <textarea class="textarea-field" value="{{form.analysis}}" bindinput="onAnalysisInput" placeholder="简要解析" auto-height></textarea>
    </view>

    <button class="btn-primary save-btn" bindtap="onSave" loading="{{stage === 'saving'}}" disabled="{{stage === 'saving'}}">保存到错题本</button>
  </view>

  <!-- 用于裁剪的离屏 canvas，始终存在 -->
  <canvas type="2d" id="cropCanvas" class="hidden-canvas"></canvas>
</view>
