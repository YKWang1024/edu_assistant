/* ========== 拍照录题 · 柔和风(紫色错题主题) ========== */
/* 选图 */
.pick-stage { padding-top: 60rpx; }
.pick-card { text-align: center; padding: 64rpx 40rpx; }
.pick-emoji { font-size: 96rpx; }
.pick-title { font-size: 36rpx; font-weight: 800; color: #2b2b33; margin: 22rpx 0 16rpx; }
.pick-tip { font-size: 26rpx; color: #8a8a97; line-height: 1.6; margin-bottom: 28rpx; }
.pick-btn { width: 100%; margin-top: 20rpx; }
/* 框选一道题 = 紫色主键 */
.pick-card .btn-primary {
  background: linear-gradient(135deg, #a78bfa 0%, #8b6fd6 100%);
  box-shadow: 0 12rpx 24rpx rgba(139, 111, 214, 0.28);
}

/* 裁剪 */
.crop-stage-wrap { margin: 0 -24rpx; }
.crop-hint { text-align: center; font-size: 26rpx; color: #8b6fd6; font-weight: 700; padding: 18rpx 0; }
.crop-stage { position: relative; margin: 0 auto; background: #20222a; overflow: hidden; }
.crop-img { position: absolute; left: 0; top: 0; }
.crop-mask { position: absolute; background: rgba(20, 22, 30, 0.58); }
.crop-box { position: absolute; border: 4rpx solid #a78bfa; box-sizing: border-box; box-shadow: 0 0 0 2rpx rgba(0, 0, 0, 0.3); }
.crop-handle {
  position: absolute;
  width: 28px;
  height: 28px;
  background: #8b6fd6;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
}
.crop-actions { display: flex; gap: 20rpx; padding: 24rpx; }
.crop-action-btn { flex: 1; }

/* 识别中 */
.loading-stage { padding-top: 120rpx; }
.loading-card { text-align: center; padding: 80rpx 40rpx; }
.loading-emoji { font-size: 80rpx; }
.loading-text { font-size: 30rpx; color: #2b2b33; margin-top: 24rpx; font-weight: 700; }
.loading-sub { font-size: 24rpx; color: #a0a0ad; margin-top: 12rpx; }

/* 整张试卷·多题 */
.multi-stage { padding-bottom: 40rpx; }
.multi-head { display: flex; align-items: center; justify-content: space-between; padding: 8rpx 4rpx 14rpx; }
.multi-head-title { font-size: 30rpx; font-weight: 800; color: #2b2b33; }
.multi-selectall {
  font-size: 24rpx;
  font-weight: 700;
  color: #8b6fd6;
  border: none;
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
  background: #efe9fb;
}
.multi-tip { font-size: 24rpx; color: #8a8a97; line-height: 1.6; margin-bottom: 18rpx; }
.m-item { margin-bottom: 18rpx; border: 2rpx solid transparent; }
.m-item.off { opacity: 0.5; }
.m-row1 { display: flex; align-items: center; gap: 14rpx; margin-bottom: 14rpx; }
.m-check {
  width: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  border: 2rpx solid #d8dbe4;
  border-radius: 12rpx;
  background: #f7f8fb;
  color: #ffffff;
  font-weight: 700;
  flex-shrink: 0;
}
.m-check.on { background: #4ca85f; border-color: #4ca85f; }
.m-badge {
  font-size: 22rpx;
  font-weight: 700;
  color: #8b6fd6;
  background: #efe9fb;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  flex-shrink: 0;
}
.m-subject { margin-left: auto; }
.m-subject-val {
  font-size: 24rpx;
  font-weight: 700;
  color: #2b2b33;
  border: 2rpx solid #eceef4;
  border-radius: 12rpx;
  padding: 10rpx 18rpx;
  background: #f7f8fb;
}
.m-stem { font-size: 28rpx; color: #2b2b33; line-height: 1.6; }
.m-options { font-size: 24rpx; color: #6b6b7a; margin-top: 8rpx; line-height: 1.6; }
.m-meta { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 14rpx; }
.m-wrong { font-size: 24rpx; color: #e5484d; font-weight: 700; }
.m-right { font-size: 24rpx; color: #4ca85f; font-weight: 700; }
.m-errorpoint {
  font-size: 24rpx;
  color: #b07a00;
  background: #fff3d6;
  border-radius: 14rpx;
  padding: 12rpx 16rpx;
  margin-top: 14rpx;
  line-height: 1.5;
}
.multi-actions { display: flex; gap: 20rpx; margin-top: 24rpx; }
.multi-action-btn { flex: 1; }

/* 编辑 */
.edit-preview { width: 100%; border: 2rpx solid #eceef4; border-radius: 16rpx; margin-bottom: 24rpx; background: #fff; }
.field-label { font-size: 26rpx; font-weight: 700; color: #6b6b7a; margin: 18rpx 0 12rpx; }
.picker-value {
  border: 2rpx solid #eceef4;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #f7f8fb;
  color: #2b2b33;
}
.opt-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 14rpx; }
.opt-key {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  font-weight: 700;
  color: #8b6fd6;
  background: #efe9fb;
  border: none;
  border-radius: 14rpx;
  flex-shrink: 0;
}
.opt-input {
  flex: 1;
  border: 2rpx solid #eceef4;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  font-size: 28rpx;
  background: #f7f8fb;
  min-width: 0;
}
.opt-correct {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #a0a0ad;
  background: #f1f3f7;
  border: none;
  border-radius: 999rpx;
  padding: 12rpx 16rpx;
}
.opt-correct.active { color: #3f8d57; background: #e3f4e0; }
.opt-del { flex-shrink: 0; font-size: 26rpx; color: #e5484d; padding: 8rpx 10rpx; }
.opt-add { font-size: 26rpx; color: #8b6fd6; font-weight: 700; padding: 14rpx 0; }
.save-btn { width: 100%; margin-top: 28rpx; }

/* 离屏 canvas */
.hidden-canvas { position: fixed; left: -9999px; top: 0; width: 10px; height: 10px; }
