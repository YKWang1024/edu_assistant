/* 选图 */
.pick-stage {
  padding-top: 60rpx;
}
.pick-card {
  text-align: center;
  padding: 60rpx 40rpx;
}
.pick-emoji {
  font-size: 96rpx;
}
.pick-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1c15;
  margin: 20rpx 0 16rpx;
  font-family: 'PingFang SC', monospace;
}
.pick-tip {
  font-size: 26rpx;
  color: #4e4634;
  line-height: 1.6;
  margin-bottom: 40rpx;
}
.pick-btn {
  width: 100%;
  margin-top: 20rpx;
}

/* 裁剪 */
.crop-stage-wrap {
  margin: 0 -24rpx; /* 抵消 container 的左右内边距，使裁剪区与屏幕同宽 */
}
.crop-hint {
  text-align: center;
  font-size: 26rpx;
  color: #5e4700;
  font-weight: 700;
  padding: 16rpx 0;
}
.crop-stage {
  position: relative;
  margin: 0 auto;
  background: #1d1c15;
  overflow: hidden;
}
.crop-img {
  position: absolute;
  left: 0;
  top: 0;
}
.crop-mask {
  position: absolute;
  background: rgba(29, 28, 21, 0.55);
}
.crop-box {
  position: absolute;
  border: 4rpx solid #e6b325;
  box-sizing: border-box;
  box-shadow: 0 0 0 2rpx rgba(0, 0, 0, 0.3);
}
.crop-handle {
  position: absolute;
  width: 28px;
  height: 28px;
  background: #e6b325;
  border: 4rpx solid #fef9ed;
  border-radius: 50%;
  box-sizing: border-box;
}
.crop-actions {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
}
.crop-action-btn {
  flex: 1;
}

/* 识别中 */
.loading-stage {
  padding-top: 120rpx;
}
.loading-card {
  text-align: center;
  padding: 80rpx 40rpx;
}
.loading-emoji {
  font-size: 80rpx;
}
.loading-text {
  font-size: 30rpx;
  color: #4e4634;
  margin-top: 24rpx;
  font-weight: 700;
}
.loading-sub {
  font-size: 24rpx;
  color: #807661;
  margin-top: 12rpx;
}

/* 整张试卷·多题 */
.multi-stage {
  padding-bottom: 40rpx;
}
.multi-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 4rpx 12rpx;
}
.multi-head-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1c15;
  font-family: 'PingFang SC', monospace;
}
.multi-selectall {
  font-size: 24rpx;
  font-weight: 700;
  color: #775a00;
  border: 2rpx solid #807661;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  background: #f2ede2;
}
.multi-tip {
  font-size: 24rpx;
  color: #4e4634;
  line-height: 1.6;
  margin-bottom: 16rpx;
}
.m-item {
  margin-bottom: 18rpx;
  border: 4rpx solid #807661;
}
.m-item.off {
  opacity: 0.45;
}
.m-row1 {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.m-check {
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  background: #fef9ed;
  color: #0c2000;
  font-weight: 700;
  flex-shrink: 0;
}
.m-check.on {
  background: #c7efa4;
  border-color: #47672c;
}
.m-badge {
  font-size: 22rpx;
  font-weight: 700;
  color: #fef9ed;
  background: #807661;
  border-radius: 6rpx;
  padding: 6rpx 12rpx;
  flex-shrink: 0;
}
.m-subject {
  margin-left: auto;
}
.m-subject-val {
  font-size: 24rpx;
  font-weight: 700;
  color: #1d1c15;
  border: 2rpx solid #807661;
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  background: #fef9ed;
}
.m-stem {
  font-size: 28rpx;
  color: #1d1c15;
  line-height: 1.6;
}
.m-options {
  font-size: 24rpx;
  color: #4e4634;
  margin-top: 8rpx;
  line-height: 1.6;
}
.m-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}
.m-wrong {
  font-size: 24rpx;
  color: #ba1a1a;
  font-weight: 700;
}
.m-right {
  font-size: 24rpx;
  color: #47672c;
  font-weight: 700;
}
.m-errorpoint {
  font-size: 24rpx;
  color: #5e4700;
  background: #fbf0cf;
  border-radius: 8rpx;
  padding: 10rpx 14rpx;
  margin-top: 12rpx;
  line-height: 1.5;
}
.multi-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.multi-action-btn {
  flex: 1;
}

/* 编辑 */
.edit-preview {
  width: 100%;
  border: 4rpx solid #807661;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  background: #fff;
}
.field-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #5e4700;
  margin: 16rpx 0 12rpx;
  font-family: 'PingFang SC', monospace;
}
.picker-value {
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  background: #fef9ed;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
  color: #1d1c15;
}
.opt-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}
.opt-key {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-weight: 700;
  color: #fef9ed;
  background: #47672c;
  border: 2rpx solid #2d441a;
  border-radius: 8rpx;
  flex-shrink: 0;
  font-family: 'PingFang SC', monospace;
}
.opt-input {
  flex: 1;
  border: 4rpx solid #807661;
  border-radius: 8rpx;
  padding: 14rpx 18rpx;
  font-size: 28rpx;
  background: #fef9ed;
  box-shadow: inset 4rpx 4rpx 0rpx 0rpx #d2c5ad;
  min-width: 0;
}
.opt-correct {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #807661;
  background: #f2ede2;
  border: 2rpx solid #807661;
  border-radius: 8rpx;
  padding: 10rpx 12rpx;
  font-family: 'PingFang SC', monospace;
}
.opt-correct.active {
  color: #0c2000;
  background: #c7efa4;
  border-color: #47672c;
}
.opt-del {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #ba1a1a;
  padding: 8rpx 10rpx;
}
.opt-add {
  font-size: 26rpx;
  color: #775a00;
  font-weight: 700;
  padding: 12rpx 0;
}
.save-btn {
  width: 100%;
  margin-top: 28rpx;
}

/* 离屏 canvas */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 10px;
  height: 10px;
}
