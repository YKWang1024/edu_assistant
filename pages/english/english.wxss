/* ========== 英语测试 · 柔和绿色风 ========== */
.select-header { text-align: center; padding: 40rpx 0 30rpx; }
.select-title { font-size: 44rpx; font-weight: 800; color: #2b2b33; margin-bottom: 10rpx; letter-spacing: -0.02em; }
.select-desc { font-size: 26rpx; color: #a0a0ad; }
.section-label { font-size: 28rpx; font-weight: 700; color: #2b2b33; margin-bottom: 16rpx; padding-left: 8rpx; }

.mode-list { margin-bottom: 30rpx; }
.mode-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 8rpx 22rpx rgba(80, 95, 130, 0.07);
  transition: transform 0.12s ease;
}
.mode-item:active { transform: scale(0.985); }
.mode-item.active { border-color: #4ca85f; background: #f4faf3; }
.mode-icon {
  width: 72rpx; height: 72rpx; border-radius: 18rpx;
  background: #e2eefe;
  display: flex; align-items: center; justify-content: center;
  font-size: 38rpx; margin-right: 18rpx; flex-shrink: 0;
}
.mode-info { flex: 1; }
.mode-name { font-size: 28rpx; font-weight: 700; color: #2b2b33; margin-bottom: 4rpx; }
.mode-desc { font-size: 22rpx; color: #9a9aa7; }
.mode-check { font-size: 30rpx; color: #4ca85f; font-weight: 800; }
.start-btn { width: 86%; margin: 20rpx auto 0; }

.progress-bar { height: 16rpx; background: #e9edf4; border-radius: 999rpx; overflow: hidden; margin-bottom: 16rpx; border: none; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #6cc06f, #4ca85f); border-radius: 999rpx; transition: width 0.3s ease; }
.progress-text { text-align: center; color: #a0a0ad; font-size: 24rpx; margin-bottom: 40rpx; font-weight: 700; }

.english-card {
  text-align: center;
  padding: 50rpx 30rpx;
  background: #ffffff;
  border: none;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(80, 95, 130, 0.08);
  margin-bottom: 30rpx;
}
.prompt-label { font-size: 26rpx; color: #a0a0ad; margin-bottom: 24rpx; }
.prompt-text { font-weight: 800; color: #2b2b33; }
.en-prompt { font-size: 72rpx; line-height: 1.2; color: #2b2b33; letter-spacing: 2rpx; }
.cn-prompt { font-size: 80rpx; color: #4ca85f; line-height: 1.2; }
.sentence-prompt { font-size: 36rpx; color: #2b2b33; line-height: 1.6; white-space: pre-line; }

.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; padding: 0 20rpx; margin-bottom: 30rpx; }
.options-grid.options-2col { grid-template-columns: 1fr 1fr; }
.option-btn {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 2rpx solid #eceef4;
  border-radius: 22rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2b2b33;
  box-shadow: 0 8rpx 22rpx rgba(80, 95, 130, 0.07);
  transition: transform 0.1s ease;
  padding: 16rpx 12rpx;
  text-align: center;
  word-break: break-all;
}
.option-btn:active { transform: scale(0.97); }
.option-btn.correct { background: #e8f6e7; border-color: #4ca85f; color: #3f8d57; }
.option-btn.wrong { background: #ffe9e6; border-color: #e5484d; color: #e5484d; }
.option-btn.show-correct { background: #e8f6e7; border-color: #4ca85f; color: #3f8d57; }

@keyframes tipPop { 0% { transform: scale(0.8); opacity: 0; } 70% { transform: scale(1.08); } 100% { transform: scale(1); opacity: 1; } }
.result-tip { text-align: center; padding: 10rpx 0; animation: tipPop 0.3s ease; }
.tip-text { font-size: 30rpx; font-weight: 700; }
.tip-correct { color: #4ca85f; }
.tip-wrong { color: #e5484d; }
