.fig {
  background: #f9fbfd;
  border: 2rpx solid #eceef4;
  border-radius: 20rpx;
  padding: 28rpx 20rpx 20rpx;
  margin: 12rpx 0 20rpx;
}

/* ---------- 计数器 ---------- */
.counter { display: flex; flex-direction: column; align-items: center; }
.counter-rods {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 72rpx;
  min-height: 220rpx;
}
.rod-col { display: flex; flex-direction: column-reverse; align-items: center; }
.rod {
  width: 10rpx;
  min-height: 200rpx;
  background: #c8cdd8;
  border-radius: 6rpx;
  display: flex;
  flex-direction: column-reverse;
  align-items: center;
  padding-bottom: 4rpx;
}
.bead {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: -6rpx;
  border-radius: 50%;
  background: #f5a623;
  border: 3rpx solid #d98a2b;
  box-shadow: inset -4rpx -4rpx 0 0 rgba(180, 120, 0, 0.18);
  transform: scale(0);
  animation: beadPop 0.3s ease forwards;
}
@keyframes beadPop {
  0% { transform: scale(0); }
  70% { transform: scale(1.15); }
  100% { transform: scale(1); }
}
.counter-base {
  width: 320rpx;
  height: 16rpx;
  background: #aeb4c2;
  border-radius: 8rpx;
  margin-top: -4rpx;
}
.counter-labels { display: flex; justify-content: center; gap: 72rpx; margin-top: 12rpx; }
.rod-label {
  min-width: 80rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #6b6b7a;
  background: #eef1f6;
  border: none;
  border-radius: 999rpx;
  padding: 6rpx 0;
}

/* ---------- 数轴 ---------- */
.numline { padding: 40rpx 30rpx 36rpx; }
.nl-axis { position: relative; height: 4rpx; background: #b5b5c0; margin: 30rpx 10rpx; }
.nl-arrow {
  position: absolute;
  right: -10rpx;
  top: -7rpx;
  width: 0; height: 0;
  border-top: 9rpx solid transparent;
  border-bottom: 9rpx solid transparent;
  border-left: 16rpx solid #b5b5c0;
}
.nl-tick { position: absolute; top: 0; transform: translateX(-50%); }
.nl-tickmark { width: 3rpx; height: 18rpx; background: #b5b5c0; margin: -7rpx auto 0; }
.nl-ticklabel { font-size: 20rpx; color: #8a8a97; margin-top: 8rpx; text-align: center; }
.nl-mark { position: absolute; top: 0; transform: translateX(-50%); }
.nl-dot { width: 18rpx; height: 18rpx; border-radius: 50%; background: #e5484d; margin: -9rpx auto 0; }
.nl-marklabel {
  position: absolute; bottom: 22rpx; left: 50%; transform: translateX(-50%);
  font-size: 26rpx; font-weight: 700; color: #e5484d; white-space: nowrap;
}

/* ---------- 几何图形 ---------- */
.shape-wrap { display: flex; flex-direction: column; align-items: center; padding: 10rpx; }
.shape-row { display: flex; align-items: center; gap: 14rpx; }
.shape-rect, .shape-circle { background: rgba(108, 192, 111, 0.22); border: 4rpx solid #4ca85f; }
.shape-rect { border-radius: 8rpx; }
.shape-circle { border-radius: 50%; }
.shape-tri {
  width: 0; height: 0;
  border-left: 90rpx solid transparent;
  border-right: 90rpx solid transparent;
  border-bottom: 156rpx solid rgba(108, 192, 111, 0.32);
}
.shape-h { font-size: 24rpx; font-weight: 700; color: #2b2b33; }
.shape-w { font-size: 24rpx; font-weight: 700; color: #2b2b33; margin-top: 10rpx; }
